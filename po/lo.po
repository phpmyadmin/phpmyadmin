#: libraries/classes/Server/Status/Variables.php:341
msgid ""
"The number of connections that were aborted because the client died without "
"closing the connection properly."
msgstr ""
"ຈຳນວນການເຊື່ອມຕໍ່ທີ່ຖືກຍົກເລີກ ເພາະໄຄລເອນ (Client) ຢຸດເຮັດວຽກໂດຍບໍ່ໄດ້ປິດການເຊື່ອມຕໍ່ໃຫ້ຖືກຕ້ອງ."

#: libraries/classes/Server/Status/Variables.php:345
msgid "The number of failed attempts to connect to the MySQL server."
msgstr "ຈຳນວນຄວາມພະຍາຍາມທີ່ລົ້ມເຫຼວໃນການເຊື່ອມຕໍ່ກັບ MySQL ເຊີເວີ."

#: libraries/classes/Server/Status/Variables.php:348
msgid ""
"The number of transactions that used the temporary binary log cache but that "
"exceeded the value of binlog_cache_size and used a temporary file to store "
"statements from the transaction."
msgstr ""
"ຈຳນວນ Transaction ທີ່ໃຊ້ແຄຊ໌ binary log ຊົ່ວຄາວ ແຕ່ມີຂະໜາດເກີນຄ່າຂອງ binlog_cache_size "
"ແລະ ຕ້ອງໃຊ້ໄຟລ໌ຊົ່ວຄາວເພື່ອເກັບຄຳສັ່ງຈາກ Transaction."

#: libraries/classes/Server/Status/Variables.php:353
msgid "The number of transactions that used the temporary binary log cache."
msgstr "ຈຳນວນ Transaction ທີ່ໃຊ້ແຄຊ໌ binary log ຊົ່ວຄາວ."

#: libraries/classes/Server/Status/Variables.php:356
msgid ""
"The number of connection attempts (successful or not) to the MySQL server."
msgstr "ຈຳນວນຄວາມພະຍາຍາມເຊື່ອມຕໍ່ກັບ MySQL ເຊີເວີ (ທັງທີ່ສຳເລັດ ແລະ ບໍ່ສຳເລັດ)."

#: libraries/classes/Server/Status/Variables.php:360
msgid ""
"The number of temporary tables on disk created automatically by the server "
"while executing statements. If Created_tmp_disk_tables is big, you may want "
"to increase the tmp_table_size  value to cause temporary tables to be memory-"
"based instead of disk-based."
msgstr ""
"ຈຳນວນຕາຕະລາງຊົ່ວຄາວໃນດິສກ໌ທີ່ຖືກສ້າງຂຶ້ນອັດຕະໂນມັດໂດຍເຊີເວີໃນຂະນະປະມວນຜົນຄຳສັ່ງ. ຫາກຄ່ານີ້ສູງ, ທ່ານ"
"ອາດຈະຕ້ອງເພີ່ມຄ່າ tmp_table_size ເພື່ອໃຫ້ຕາຕະລາງຊົ່ວຄາວຖືກສ້າງໃນໜ່ວຍຄວາມຈຳແທນດິສກ໌."

#: libraries/classes/Server/Status/Variables.php:367
msgid "How many temporary files mysqld has created."
msgstr "ຈຳນວນໄຟລ໌ຊົ່ວຄາວທີ່ mysqld ໄດ້ສ້າງຂຶ້ນ."

#: libraries/classes/Server/Status/Variables.php:370
msgid ""
"The number of in-memory temporary tables created automatically by the server "
"while executing statements."
msgstr ""
"ຈຳນວນຕາຕະລາງຊົ່ວຄາວໃນໜ່ວຍຄວາມຈຳທີ່ຖືກສ້າງຂຶ້ນອັດຕະໂນມັດໂດຍເຊີເວີໃນຂະນະປະມວນຜົນຄຳສັ່ງ."

#: libraries/classes/Server/Status/Variables.php:374
msgid ""
"The number of rows written with INSERT DELAYED for which some error occurred "
"(probably duplicate key)."
msgstr ""
"ຈຳນວນແຖວທີ່ຂຽນດ້ວຍ INSERT DELAYED ແລ້ວເກີດຂໍ້ຜິດພາດ (ອາດຈະເປັນເພາະຄີຊ້ຳ)."

#: libraries/classes/Server/Status/Variables.php:378
msgid ""
"The number of INSERT DELAYED handler threads in use. Every different table "
"on which one uses INSERT DELAYED gets its own thread."
msgstr "ຈຳນວນ thread ຂອງ INSERT DELAYED handler ທີ່ກຳລັງໃຊ້ງານ."

#: libraries/classes/Server/Status/Variables.php:383
msgid "The number of INSERT DELAYED rows written."
msgstr "ຈຳນວນແຖວທີ່ຂຽນດ້ວຍ INSERT DELAYED."

#: libraries/classes/Server/Status/Variables.php:386
msgid "The number of executed FLUSH statements."
msgstr "ຈຳນວນຄຳສັ່ງ FLUSH ທີ່ໄດ້ປະມວນຜົນ."

#: libraries/classes/Server/Status/Variables.php:389
msgid "The number of internal COMMIT statements."
msgstr "ຈຳນວນຄຳສັ່ງ COMMIT ພາຍໃນ."

#: libraries/classes/Server/Status/Variables.php:392
msgid "The number of times a row was deleted from a table."
msgstr "ຈຳນວນຄັ້ງທີ່ມີການລຶບແຖວອອກຈາກຕາຕະລາງ."

#: libraries/classes/Server/Status/Variables.php:395
msgid ""
"The MySQL server can ask the NDB Cluster storage engine if it knows about a "
"table with a given name. This is called discovery. Handler_discover "
"indicates the number of time tables have been discovered."
msgstr ""
"ຈຳນວນຄັ້ງທີ່ມີການຄົ້ນຫາຕາຕະລາງ (discovery) ຜ່ານ NDB Cluster storage engine."

#: libraries/classes/Server/Status/Variables.php:401
msgid ""
"The number of times the first entry was read from an index. If this is high, "
"it suggests that the server is doing a lot of full index scans; for example, "
"SELECT col1 FROM foo, assuming that col1 is indexed."
msgstr ""
"ຈຳນວນຄັ້ງທີ່ມີການອ່ານລາຍການທຳອິດຈາກ index. ຫາກຄ່ານີ້ສູງ ສະແດງວ່າເຊີເວີກຳລັງເຮັດ full index "
"scans ເປັນຈຳນວນຫຼາຍ."

#: libraries/classes/Server/Status/Variables.php:407
msgid ""
"The number of requests to read a row based on a key. If this is high, it is "
"a good indication that your queries and tables are properly indexed."
msgstr ""
"ຈຳນວນຄຳຮ້ອງຂໍອ່ານແຖວໂດຍອີງຕາມຄີ (key). ຫາກຄ່ານີ້ສູງ ສະແດງວ່າ Query ແລະ ຕາຕະລາງມີການເຮັດ "
"Index ທີ່ດີແລ້ວ."

#: libraries/classes/Server/Status/Variables.php:412
msgid ""
"The number of requests to read the next row in key order. This is "
"incremented if you are querying an index column with a range constraint or "
"if you are doing an index scan."
msgstr "ຈຳນວນຄຳຮ້ອງຂໍອ່ານແຖວຖັດໄປຕາມລຳດັບຂອງຄີ."

#: libraries/classes/Server/Status/Variables.php:417
msgid ""
"The number of requests to read the previous row in key order. This read "
"method is mainly used to optimize ORDER BY … DESC."
msgstr ""
"ຈຳນວນຄຳຮ້ອງຂໍອ່ານແຖວກ່ອນໜ້າຕາມລຳດັບຂອງຄີ. ໃຊ້ເພື່ອປັບແຕ່ງ ORDER BY … DESC."

#: libraries/classes/Server/Status/Variables.php:421
msgid ""
"The number of requests to read a row based on a fixed position. This is high "
"if you are doing a lot of queries that require sorting of the result. You "
"probably have a lot of queries that require MySQL to scan whole tables or "
"you have joins that don't use keys properly."
msgstr ""
"ຈຳນວນຄຳຮ້ອງຂໍອ່ານແຖວຕາມຕຳແໜ່ງທີ່ແນ່ນອນ. ຫາກຄ່ານີ້ສູງ ສະແດງວ່າມີ Query ທີ່ຕ້ອງມີການຈັດລຽງຜົນລັບ ຫຼື "
"ມີການ scan ທັງຕາຕະລາງ ຫຼື ການ join ທີ່ບໍ່ໄດ້ໃຊ້ຄີຢ່າງຖືກຕ້ອງ."

#: libraries/classes/Server/Status/Variables.php:428
msgid ""
"The number of requests to read the next row in the data file. This is high "
"if you are doing a lot of table scans. Generally this suggests that your "
"tables are not properly indexed or that your queries are not written to take "
"advantage of the indexes you have."
msgstr ""
"ຈຳນວນຄຳຮ້ອງຂໍອ່ານແຖວຖັດໄປໃນໄຟລ໌ຂໍ້ມູນ. ຫາກຄ່ານີ້ສູງ ສະແດງວ່າມີການ scan ຕາຕະລາງຫຼາຍ ເຊິ່ງມັກຈະໝາ"
"ຍເຖິງຕາຕະລາງບໍ່ໄດ້ເຮັດ Index ຫຼື Query ບໍ່ໄດ້ໃຊ້ປະໂຫຍດຈາກ Index ທີ່ມີ."

#: libraries/classes/Server/Status/Variables.php:435
msgid "The number of internal ROLLBACK statements."
msgstr "ຈຳນວນຄຳສັ່ງ ROLLBACK ພາຍໃນ."

#: libraries/classes/Server/Status/Variables.php:438
msgid "The number of requests to update a row in a table."
msgstr "ຈຳນວນຄຳຮ້ອງຂໍແກ້ໄຂແຖວໃນຕາຕະລາງ."

#: libraries/classes/Server/Status/Variables.php:441
msgid "The number of requests to insert a row in a table."
msgstr "ຈຳນວນຄຳຮ້ອງຂໍເພີ່ມແຖວໃນຕາຕະລາງ."

#: libraries/classes/Server/Status/Variables.php:444
msgid "The number of pages containing data (dirty or clean)."
msgstr "ຈຳນວນ Page ທີ່ມີຂໍ້ມູນ (ທັງ dirty ແລະ clean)."

#: libraries/classes/Server/Status/Variables.php:447
msgid "The number of pages currently dirty."
msgstr "ຈຳນວນ Page ທີ່ເປັນ dirty ຢູ່ໃນຂະນະນີ້."

#: libraries/classes/Server/Status/Variables.php:450
msgid "The number of buffer pool pages that have been requested to be flushed."
msgstr "ຈຳນວນ buffer pool pages ທີ່ຖືກຮ້ອງຂໍໃຫ້ flush."

#: libraries/classes/Server/Status/Variables.php:454
msgid "The number of free pages."
msgstr "ຈຳນວນ Page ທີ່ວ່າງ."

#: libraries/classes/Server/Status/Variables.php:457
msgid ""
"The number of latched pages in InnoDB buffer pool. These are pages currently "
"being read or written or that can't be flushed or removed for some other "
"reason."
msgstr "ຈຳນວນ Page ໃນ InnoDB buffer pool ທີ່ຖືກລັອກ (latched) ໄວ້."

#: libraries/classes/Server/Status/Variables.php:462
msgid ""
"The number of pages busy because they have been allocated for administrative "
"overhead such as row locks or the adaptive hash index. This value can also "
"be calculated as Innodb_buffer_pool_pages_total - "
"Innodb_buffer_pool_pages_free - Innodb_buffer_pool_pages_data."
msgstr "ຈຳນວນ Page ທີ່ກຳລັງຖືກໃຊ້ງານສຳລັບວຽກບໍລິຫານລະບົບ."

#: libraries/classes/Server/Status/Variables.php:469
msgid "Total size of buffer pool, in pages."
msgstr "ຂະໜາດທັງໝົດຂອງ buffer pool (ຫົວໜ່ວຍເປັນ Page)."

#: libraries/classes/Server/Status/Variables.php:472
msgid ""
"The number of \"random\" read-aheads InnoDB initiated. This happens when a "
"query is to scan a large portion of a table but in random order."
msgstr "ຈຳນວນການອ່ານຂໍ້ມູນລ່ວງໜ້າແບບ \"ສຸ່ມ\" ທີ່ InnoDB ເລີ່ມຕົ້ນ."

#: libraries/classes/Server/Status/Variables.php:477
msgid ""
"The number of sequential read-aheads InnoDB initiated. This happens when "
"InnoDB does a sequential full table scan."
msgstr "ຈຳນວນການອ່ານຂໍ້ມູນລ່ວງໜ້າແບບ \"ລຽງລຳດັບ\" ທີ່ InnoDB ເລີ່ມຕົ້ນ."

#: libraries/classes/Server/Status/Variables.php:481
msgid "The number of logical read requests InnoDB has done."
msgstr "ຈຳນວນຄຳຮ້ອງຂໍອ່ານແບບ logical ທີ່ InnoDB ໄດ້ເຮັດ."

#: libraries/classes/Server/Status/Variables.php:484
msgid ""
"The number of logical reads that InnoDB could not satisfy from buffer pool "
"and had to do a single-page read."
msgstr ""
"ຈຳນວນການອ່ານແບບ logical ທີ່ InnoDB ບໍ່ພົບໃນ buffer pool ແລະ ຕ້ອງອ່ານຈາກດິສກ໌."

#: libraries/classes/Server/Status/Variables.php:488
msgid ""
"Normally, writes to the InnoDB buffer pool happen in the background. "
"However, if it's necessary to read or create a page and no clean pages are "
"available, it's necessary to wait for pages to be flushed first. This "
"counter counts instances of these waits. If the buffer pool size was set "
"properly, this value should be small."
msgstr ""
"ຈຳນວນຄັ້ງທີ່ຕ້ອງລໍຖ້າໃຫ້ມີການ flush page ເພາະບໍ່ມີ page ວ່າງໃນ buffer pool. ຫາກຕັ້ງຂະໜາດ "
"buffer pool ຢ່າງເໝາະສົມ ຄ່ານີ້ຄວນຈະໜ້ອຍ."

#: libraries/classes/Server/Status/Variables.php:496
msgid "The number writes done to the InnoDB buffer pool."
msgstr "ຈຳນວນການຂຽນຂໍ້ມູນລົງໃນ InnoDB buffer pool."

#: libraries/classes/Server/Status/Variables.php:499
msgid "The number of fsync() operations so far."
msgstr "ຈຳນວນການເຮັດ fsync() ທັງໝົດທີ່ຜ່ານມາ."

#: libraries/classes/Server/Status/Variables.php:502
msgid "The current number of pending fsync() operations."
msgstr "ຈຳນວນການເຮັດ fsync() ທີ່ຍັງຄ້າງຢູ່."

#: libraries/classes/Server/Status/Variables.php:505
msgid "The current number of pending reads."
msgstr "ຈຳນວນການອ່ານທີ່ຍັງຄ້າງຢູ່."

#: libraries/classes/Server/Status/Variables.php:508
msgid "The current number of pending writes."
msgstr "ຈຳນວນການຂຽນທີ່ຍັງຄ້າງຢູ່."

#: libraries/classes/Server/Status/Variables.php:511
msgid "The amount of data read so far, in bytes."
msgstr "ປະລິມານຂໍ້ມູນທີ່ອ່ານໄປແລ້ວ (ຫົວໜ່ວຍເປັນໄບຕ໌)."

#: libraries/classes/Server/Status/Variables.php:514
msgid "The total number of data reads."
msgstr "ຈຳນວນຄັ້ງທັງໝົດໃນການອ່ານຂໍ້ມູນ."

#: libraries/classes/Server/Status/Variables.php:517
msgid "The total number of data writes."
msgstr "ຈຳນວນຄັ້ງທັງໝົດໃນການຂຽນຂໍ້ມູນ."

#: libraries/classes/Server/Status/Variables.php:520
msgid "The amount of data written so far, in bytes."
msgstr "ປະລິມານຂໍ້ມູນທີ່ຂຽນໄປແລ້ວ (ຫົວໜ່ວຍເປັນໄບຕ໌)."

#: libraries/classes/Server/Status/Variables.php:523
msgid "The number of pages that have been written for doublewrite operations."
msgstr "ຈຳນວນ Page ທີ່ຂຽນສຳລັບການເຮັດ doublewrite."

#: libraries/classes/Server/Status/Variables.php:527
msgid "The number of doublewrite operations that have been performed."
msgstr "ຈຳນວນຄັ້ງທີ່ມີການເຮັດ doublewrite."

#: libraries/classes/Server/Status/Variables.php:530
msgid ""
"The number of waits we had because log buffer was too small and we had to "
"wait for it to be flushed before continuing."
msgstr "ຈຳນວນຄັ້ງທີ່ຕ້ອງລໍຖ້າເພາະ log buffer ນ້ອຍເກີນໄປ."

#: libraries/classes/Server/Status/Variables.php:534
msgid "The number of log write requests."
msgstr "ຈຳນວນຄຳຮ້ອງຂໍຂຽນ log."

#: libraries/classes/Server/Status/Variables.php:537
msgid "The number of physical writes to the log file."
msgstr "ຈຳນວນຄັ້ງທີ່ມີການຂຽນລົງໄຟລ໌ log ແທ້ໆ."

#: libraries/classes/Server/Status/Variables.php:540
msgid "The number of fsync() writes done to the log file."
msgstr "ຈຳນວນການຂຽນແບບ fsync() ລົງໃນໄຟລ໌ log."

#: libraries/classes/Server/Status/Variables.php:543
msgid "The number of pending log file fsyncs."
msgstr "ຈຳນວນ fsync ຂອງໄຟລ໌ log ທີ່ຍັງຄ້າງຢູ່."

#: libraries/classes/Server/Status/Variables.php:546
msgid "Pending log file writes."
msgstr "ການຂຽນໄຟລ໌ log ທີ່ຍັງຄ້າງຢູ່."

#: libraries/classes/Server/Status/Variables.php:549
msgid "The number of bytes written to the log file."
msgstr "ຈຳນວນໄບຕ໌ທີ່ຂຽນລົງໃນໄຟລ໌ log."

#: libraries/classes/Server/Status/Variables.php:552
msgid "The number of pages created."
msgstr "ຈຳນວນ Page ທີ່ຖືກສ້າງຂຶ້ນ."

#: libraries/classes/Server/Status/Variables.php:555
msgid ""
"The compiled-in InnoDB page size (default 16KB). Many values are counted in "
"pages; the page size allows them to be easily converted to bytes."
msgstr "ຂະໜາດ Page ຂອງ InnoDB (ຄ່າເລີ່ມຕົ້ນແມ່ນ 16KB)."

#: libraries/classes/Server/Status/Variables.php:560
msgid "The number of pages read."
msgstr "ຈຳນວນ Page ທີ່ຖືກອ່ານ."

#: libraries/classes/Server/Status/Variables.php:563
msgid "The number of pages written."
msgstr "ຈຳນວນ Page ທີ່ຖືກຂຽນ."

#: libraries/classes/Server/Status/Variables.php:566
msgid "The number of row locks currently being waited for."
msgstr "ຈຳນວນແຖວທີ່ຖືກລັອກ ແລະ ກຳລັງລໍຖ້າຢູ່ໃນຂະນະນີ້."

#: libraries/classes/Server/Status/Variables.php:569
msgid "The average time to acquire a row lock, in milliseconds."
msgstr "ເວລາສະເລ່ຍໃນການຂໍລັອກແຖວ (ຫົວໜ່ວຍເປັນມິລລິວິນາທີ)."

#: libraries/classes/Server/Status/Variables.php:572
msgid "The total time spent in acquiring row locks, in milliseconds."
msgstr "ເວລາທັງໝົດທີ່ໃຊ້ໃນການຂໍລັອກແຖວ (ຫົວໜ່ວຍເປັນມິລລິວິນາທີ)."

#: libraries/classes/Server/Status/Variables.php:575
msgid "The maximum time to acquire a row lock, in milliseconds."
msgstr "ເວລາດົນທີ່ສຸດໃນການຂໍລັອກແຖວ (ຫົວໜ່ວຍເປັນມິລລິວິນາທີ)."

#: libraries/classes/Server/Status/Variables.php:578
msgid "The number of times a row lock had to be waited for."
msgstr "ຈຳນວນຄັ້ງທີ່ຕ້ອງລໍຖ້າການລັອກແຖວ."

#: libraries/classes/Server/Status/Variables.php:581
msgid "The number of rows deleted from InnoDB tables."
msgstr "ຈຳນວນແຖວທີ່ຖືກລຶບອອກຈາກຕາຕະລາງ InnoDB."

#: libraries/classes/Server/Status/Variables.php:584
msgid "The number of rows inserted in InnoDB tables."
msgstr "ຈຳນວນແຖວທີ່ຖືກເພີ່ມເຂົ້າໃນຕາຕະລາງ InnoDB."

#: libraries/classes/Server/Status/Variables.php:587
msgid "The number of rows read from InnoDB tables."
msgstr "ຈຳນວນແຖວທີ່ຖືກອ່ານຈາກຕາຕະລາງ InnoDB."

#: libraries/classes/Server/Status/Variables.php:590
msgid "The number of rows updated in InnoDB tables."
msgstr "ຈຳນວນແຖວທີ່ຖືກແກ້ໄຂໃນຕາຕະລາງ InnoDB."

#: libraries/classes/Server/Status/Variables.php:593
msgid ""
"The number of key blocks in the key cache that have changed but haven't yet "
"been flushed to disk. It used to be known as Not_flushed_key_blocks."
msgstr "ຈຳນວນ key blocks ໃນ key cache ທີ່ຖືກແກ້ໄຂແລ້ວແຕ່ຍັງບໍ່ໄດ້ຂຽນລົງດິສກ໌."

#: libraries/classes/Server/Status/Variables.php:598
msgid ""
"The number of unused blocks in the key cache. You can use this value to "
"determine how much of the key cache is in use."
msgstr "ຈຳນວນ block ທີ່ຍັງບໍ່ໄດ້ໃຊ້ໃນ key cache."

#: libraries/classes/Server/Status/Variables.php:602
msgid ""
"The number of used blocks in the key cache. This value is a high-water mark "
"that indicates the maximum number of blocks that have ever been in use at "
"one time."
msgstr "ຈຳນວນ block ທີ່ຖືກໃຊ້ງານໃນ key cache (ຄ່າສູງສຸດທີ່ເຄີຍໃຊ້)."

#: libraries/classes/Server/Status/Variables.php:607
msgid "Percentage of used key cache (calculated value)"
msgstr "ເປີເຊັນຂອງ key cache ທີ່ຖືກໃຊ້ງານ (ຄ່າຈາກການຄິດໄລ່)"

#: libraries/classes/Server/Status/Variables.php:610
msgid "The number of requests to read a key block from the cache."
msgstr "ຈຳນວນຄຳຮ້ອງຂໍອ່ານ key block ຈາກແຄຊ໌."

#: libraries/classes/Server/Status/Variables.php:613
msgid ""
"The number of physical reads of a key block from disk. If Key_reads is big, "
"then your key_buffer_size value is probably too small. The cache miss rate "
"can be calculated as Key_reads/Key_read_requests."
msgstr ""
"ຈຳນວນການອ່ານ key block ຈາກດິສກ໌. ຫາກຄ່ານີ້ສູງ ສະແດງວ່າຄ່າ key_buffer_size ອາດຈະນ້ອຍເກີນໄ"
"ປ."

#: libraries/classes/Server/Status/Variables.php:619
msgid ""
"Key cache miss calculated as rate of physical reads compared to read "
"requests (calculated value)"
msgstr "ອັດຕາການອ່ານບໍ່ພົບໃນແຄຊ໌ (Cache miss) ປຽບທຽບກັບການຮ້ອງຂໍທັງໝົດ."

#: libraries/classes/Server/Status/Variables.php:623
msgid "The number of requests to write a key block to the cache."
msgstr "ຈຳນວນຄຳຮ້ອງຂໍຂຽນ key block ລົງໃນແຄຊ໌."

#: libraries/classes/Server/Status/Variables.php:626
msgid "The number of physical writes of a key block to disk."
msgstr "ຈຳນວນການຂຽນ key block ລົງໃນດິສກ໌ແທ້ໆ."

#: libraries/classes/Server/Status/Variables.php:629
msgid ""
"Percentage of physical writes compared to write requests (calculated value)"
msgstr "ເປີເຊັນການຂຽນລົງດິສກ໌ແທ້ໆ ປຽບທຽບກັບການຮ້ອງຂໍຂຽນ (ຄ່າຈາກການຄິດໄລ່)."

#: libraries/classes/Server/Status/Variables.php:633
msgid ""
"The total cost of the last compiled query as computed by the query "
"optimizer. Useful for comparing the cost of different query plans for the "
"same query. The default value of 0 means that no query has been compiled yet."
msgstr "ຄ່າໃຊ້ຈ່າຍ (Cost) ທັງໝົດຂອງ query ສຸດທ້າຍ ທີ່ຄິດໄລ່ໂດຍ query optimizer."

#: libraries/classes/Server/Status/Variables.php:639
msgid ""
"The maximum number of connections that have been in use simultaneously since "
"the server started."
msgstr "ຈຳນວນການເຊື່ອມຕໍ່ພ້ອມກັນສູງສຸດ ຕັ້ງແຕ່ເລີ່ມເຊີເວີ."

#: libraries/classes/Server/Status/Variables.php:643
msgid "The number of rows waiting to be written in INSERT DELAYED queues."
msgstr "ຈຳນວນແຖວທີ່ລໍຖ້າຂຽນໃນຄິວຂອງ INSERT DELAYED."

#: libraries/classes/Server/Status/Variables.php:646
msgid ""
"The number of tables that have been opened. If opened tables is big, your "
"table cache value is probably too small."
msgstr ""
"ຈຳນວນຕາຕະລາງທີ່ຖືກເປີດ. ຫາກຄ່ານີ້ສູງ ສະແດງວ່າຄ່າ table cache ອາດຈະນ້ອຍເກີນໄປ."

#: libraries/classes/Server/Status/Variables.php:650
msgid "The number of files that are open."
msgstr "ຈຳນວນໄຟລ໌ທີ່ເປີດຢູ່."

#: libraries/classes/Server/Status/Variables.php:653
msgid "The number of streams that are open (used mainly for logging)."
msgstr "ຈຳນວນ stream ທີ່ເປີດຢູ່ (ສ່ວນໃຫຍ່ໃຊ້ສຳລັບການເຮັດ log)."

#: libraries/classes/Server/Status/Variables.php:656
msgid "The number of tables that are open."
msgstr "ຈຳນວນຕາຕະລາງທີ່ເປີດຢູ່."

#: libraries/classes/Server/Status/Variables.php:659
msgid ""
"The number of free memory blocks in query cache. High numbers can indicate "
"fragmentation issues, which may be solved by issuing a FLUSH QUERY CACHE "
"statement."
msgstr "ຈຳນວນ memory block ທີ່ວ່າງໃນ query cache."

#: libraries/classes/Server/Status/Variables.php:664
msgid "The amount of free memory for query cache."
msgstr "ປະລິມານໜ່ວຍຄວາມຈຳທີ່ວ່າງສຳລັບ query cache."

#: libraries/classes/Server/Status/Variables.php:667
msgid "The number of cache hits."
msgstr "ຈຳນວນຄັ້ງທີ່ພົບຂໍ້ມູນໃນແຄຊ໌ (Cache hits)."

#: libraries/classes/Server/Status/Variables.php:670
msgid "The number of queries added to the cache."
msgstr "ຈຳນວນ query ທີ່ຖືກເພີ່ມເຂົ້າໃນແຄຊ໌."

#: libraries/classes/Server/Status/Variables.php:673
msgid ""
"The number of queries that have been removed from the cache to free up "
"memory for caching new queries. This information can help you tune the query "
"cache size. The query cache uses a least recently used (LRU) strategy to "
"decide which queries to remove from the cache."
msgstr "ຈຳນວນ query ທີ່ຖືກລຶບອອກຈາກແຄຊ໌ເພື່ອເພີ່ມບ່ອນວ່າງ."

#: libraries/classes/Server/Status/Variables.php:680
msgid ""
"The number of non-cached queries (not cachable, or not cached due to the "
"query_cache_type setting)."
msgstr "ຈຳນວນ query ທີ່ບໍ່ໄດ້ຖືກເກັບໃນແຄຊ໌."

#: libraries/classes/Server/Status/Variables.php:684
msgid "The number of queries registered in the cache."
msgstr "ຈຳນວນ query ທີ່ລົງທະບຽນໄວ້ໃນແຄຊ໌."

#: libraries/classes/Server/Status/Variables.php:687
msgid "The total number of blocks in the query cache."
msgstr "ຈຳນວນ block ທັງໝົດໃນ query cache."

#: libraries/classes/Server/Status/Variables.php:690
msgid "The status of failsafe replication (not yet implemented)."
msgstr "ສະຖານະຂອງ failsafe replication (ຍັງບໍ່ໄດ້ເປີດໃຊ້)."

#: libraries/classes/Server/Status/Variables.php:693
msgid ""
"The number of joins that do not use indexes. If this value is not 0, you "
"should carefully check the indexes of your tables."
msgstr "ຈຳນວນການ join ທີ່ບໍ່ໄດ້ໃຊ້ Index."

#: libraries/classes/Server/Status/Variables.php:697
msgid "The number of joins that used a range search on a reference table."
msgstr "ຈຳນວນການ join ທີ່ໃຊ້ການຄົ້ນຫາແບບຊ່ວງ (range search) ໃນຕາຕະລາງອ້າງອີງ."

#: libraries/classes/Server/Status/Variables.php:700
msgid ""
"The number of joins without keys that check for key usage after each row. "
"(If this is not 0, you should carefully check the indexes of your tables.)"
msgstr "ຈຳນວນການ join ທີ່ບໍ່ມີຄີ (key)."

#: libraries/classes/Server/Status/Variables.php:705
msgid ""
"The number of joins that used ranges on the first table. (It's normally not "
"critical even if this is big.)"
msgstr "ຈຳນວນການ join ທີ່ໃຊ້ຊ່ວງ (ranges) ໃນຕາຕະລາງທຳອິດ."

#: libraries/classes/Server/Status/Variables.php:709
msgid "The number of joins that did a full scan of the first table."
msgstr "ຈຳນວນການ join ທີ່ເຮັດ full scan ໃນຕາຕະລາງທຳອິດ."

#: libraries/classes/Server/Status/Variables.php:712
msgid "The number of temporary tables currently open by the slave SQL thread."
msgstr "ຈຳນວນຕາຕະລາງຊົ່ວຄາວທີ່ເປີດໂດຍ slave SQL thread ຢູ່ໃນຂະນະນີ້."

#: libraries/classes/Server/Status/Variables.php:716
msgid ""
"Total (since startup) number of times the replication slave SQL thread has "
"retried transactions."
msgstr "ຈຳນວນຄັ້ງທັງໝົດທີ່ slave SQL thread ລອງເຮັດ transaction ໃໝ່."

#: libraries/classes/Server/Status/Variables.php:720
msgid "This is ON if this server is a slave that is connected to a master."
msgstr "ຈະເປັນ ON ຫາກເຊີເວີນີ້ເປັນ slave ທີ່ເຊື່ອມຕໍ່ກັບ master ຢູ່."

#: libraries/classes/Server/Status/Variables.php:723
msgid ""
"The number of threads that have taken more than slow_launch_time seconds to "
"create."
msgstr "ຈຳນວນ thread ທີ່ໃຊ້ເວລາສ້າງດົນເກີນຄ່າ slow_launch_time."

#: libraries/classes/Server/Status/Variables.php:727
msgid ""
"The number of queries that have taken more than long_query_time seconds."
msgstr "ຈຳນວນ query ທີ່ໃຊ້ເວລາດົນເກີນຄ່າ long_query_time."

#: libraries/classes/Server/Status/Variables.php:731
msgid ""
"The number of merge passes the sort algorithm has had to do. If this value "
"is large, you should consider increasing the value of the sort_buffer_size "
"system variable."
msgstr "ຈຳນວນ merge passes ທີ່ algorithm ການຈັດລຽງຕ້ອງເຮັດ."

#: libraries/classes/Server/Status/Variables.php:736
msgid "The number of sorts that were done with ranges."
msgstr "ຈຳນວນການຈັດລຽງທີ່ເຮັດດ້ວຍຊ່ວງ (ranges)."

#: libraries/classes/Server/Status/Variables.php:739
msgid "The number of sorted rows."
msgstr "ຈຳນວນແຖວທີ່ຖືກຈັດລຽງແລ້ວ."

#: libraries/classes/Server/Status/Variables.php:742
msgid "The number of sorts that were done by scanning the table."
msgstr "ຈຳນວນການຈັດລຽງທີ່ເຮັດໂດຍການ scan ຕາຕະລາງ."

#: libraries/classes/Server/Status/Variables.php:745
msgid "The number of times that a table lock was acquired immediately."
msgstr "ຈຳນວນຄັ້ງທີ່ສາມາດລັອກຕາຕະລາງໄດ້ທັນທີ."

#: libraries/classes/Server/Status/Variables.php:748
msgid ""
"The number of times that a table lock could not be acquired immediately and "
"a wait was needed. If this is high, and you have performance problems, you "
"should first optimize your queries, and then either split your table or "
"tables or use replication."
msgstr "ຈຳນວນຄັ້ງທີ່ບໍ່ສາມາດລັອກຕາຕະລາງໄດ້ທັນທີ ແລະ ຕ້ອງລໍຖ້າ."

#: libraries/classes/Server/Status/Variables.php:754
msgid ""
"The number of threads in the thread cache. The cache hit rate can be "
"calculated as Threads_created/Connections. If this value is red you should "
"raise your thread_cache_size."
msgstr "ຈຳນວນ thread ໃນ thread cache."

#: libraries/classes/Server/Status/Variables.php:759
msgid "The number of currently open connections."
msgstr "ຈຳນວນການເຊື່ອມຕໍ່ທີ່ເປີດຢູ່ໃນຂະນະນີ້."

#: libraries/classes/Server/Status/Variables.php:762
msgid ""
"The number of threads created to handle connections. If Threads_created is "
"big, you may want to increase the thread_cache_size value. (Normally this "
"doesn't give a notable performance improvement if you have a good thread "
"implementation.)"
msgstr "ຈຳນວນ thread ທີ່ຖືກສ້າງຂຶ້ນເພື່ອຈັດການການເຊື່ອມຕໍ່."

