#: libraries/classes/Config/Descriptions.php:58
#: libraries/classes/Config/Descriptions.php:59
#: libraries/classes/Config/Descriptions.php:60
msgid "Users cannot set a higher value"
msgstr "ຜູ້ໃຊ້ບໍ່ສາມາດຕັ້ງຄ່າໃຫ້ສູງກວ່ານີ້ໄດ້"

#: libraries/classes/Config/Descriptions.php:68
msgid ""
"If enabled, user can enter any MySQL server in login form for cookie auth."
msgstr ""
"ຫາກເປີດໃຊ້, ຜູ້ໃຊ້ສາມາດປ້ອນ MySQL ເຊີເວີໃດກໍໄດ້ໃນຟອມເຂົ້າສູ່ລະບົບສຳລັບການຢືນຢັນຕົວຕົນດ້ວຍຄຸກກີ້."

#: libraries/classes/Config/Descriptions.php:71
msgid ""
"Restricts the MySQL servers the user can enter when a login to an arbitrary "
"MySQL server is enabled by matching the IP or hostname of the MySQL server "
"to the given regular expression."
msgstr ""
"ຈຳກັດ MySQL ເຊີເວີທີ່ຜູ້ໃຊ້ສາມາດປ້ອນໄດ້ ເມື່ອເປີດໃຊ້ການເຂົ້າສູ່ລະບົບແບບກຳນົດເອງ ໂດຍການປຽບທຽບ IP "
"ຫຼື ຊື່ໂຮສຂອງ MySQL ເຊີເວີ ກັບ regular expression ທີ່ກຳນົດ."

#: libraries/classes/Config/Descriptions.php:76
msgid ""
"Enabling this allows a page located on a different domain to call phpMyAdmin "
"inside a frame, and is a potential [strong]security hole[/strong] allowing "
"cross-frame scripting (XSS) attacks."
msgstr ""
"ການເປີດໃຊ້ສິ່ງນີ້ອະນຸຍາດໃຫ້ໜ້າເວັບໃນໂດເມນອື່ນເອີ້ນໃຊ້ phpMyAdmin ພາຍໃນເຟຣມໄດ້, ຊຶ່ງອາດເປັນ "
"[strong]ຊ່ອງໂຫວ່ດ້ານຄວາມປອດໄພ[/strong] ທີ່ອະນຸຍາດໃຫ້ມີການໂຈມຕີແບບ cross-frame "
"scripting (XSS)."

#: libraries/classes/Config/Descriptions.php:81
msgid ""
"Secret passphrase used for encrypting cookies in [kbd]cookie[/kbd] "
"authentication."
msgstr ""
"ລະຫັດລັບທີ່ໃຊ້ສຳລັບການເຂົ້າລະຫັດຄຸກກີ້ໃນການຢືນຢັນຕົວຕົນແບບ [kbd]cookie[/kbd]."

#: libraries/classes/Config/Descriptions.php:85
msgid "Enable bzip2 compression for import operations."
msgstr "ເປີດໃຊ້ການບີບອັດ bzip2 ສຳລັບການນຳເຂົ້າ."

#: libraries/classes/Config/Descriptions.php:88
msgid "Enter the URL for your reCaptcha v2 compatible API."
msgstr "ປ້ອນ URL ສຳລັບ API ທີ່ຮອງຮັບ reCaptcha v2 ຂອງເຈົ້າ."

#: libraries/classes/Config/Descriptions.php:89
msgid ""
"Enter the Content-Security-Policy snippet for your reCaptcha v2 compatible "
"API."
msgstr ""
"ປ້ອນ Content-Security-Policy snippet ສຳລັບ API ທີ່ຮອງຮັບ reCaptcha v2 ຂອງເຈົ້າ."

#: libraries/classes/Config/Descriptions.php:90
msgid "Enter the request parameter used by your reCaptcha v2 compatible API."
msgstr "ປ້ອນຕົວປ່ຽນ request ທີ່ໃຊ້ໂດຍ API reCaptcha v2 ຂອງເຈົ້າ."

#: libraries/classes/Config/Descriptions.php:91
msgid "Enter the response parameter used by your reCaptcha v2 compatible API."
msgstr "ປ້ອນຕົວປ່ຽນ response ທີ່ໃຊ້ໂດຍ API reCaptcha v2 ຂອງເຈົ້າ."

#: libraries/classes/Config/Descriptions.php:92
msgid "Enter your public key for your domain reCaptcha service."
msgstr "ໃສ່ Public key ສຳລັບບໍລິການ reCaptcha ຂອງໂດເມນຂອງທ່ານ."

#: libraries/classes/Config/Descriptions.php:93
msgid "Enter your private key for your domain reCaptcha service."
msgstr "ໃສ່ Private key ສຳລັບບໍລິການ reCaptcha ຂອງໂດເມນຂອງທ່ານ."

#: libraries/classes/Config/Descriptions.php:94
msgid "Enter your siteverify URL for your reCaptcha service."
msgstr "ປ້ອນ URL ສຳລັບການຢືນຢັນເວັບໄຊ (siteverify) ຂອງບໍລິການ reCaptcha."

#: libraries/classes/Config/Descriptions.php:96
msgid ""
"Defines which type of editing controls should be used for CHAR and VARCHAR "
"columns; [kbd]input[/kbd] - allows limiting of input length, [kbd]textarea[/"
"kbd] - allows newlines in columns."
msgstr ""
"ກຳນົດຮູບແບບການແກ້ໄຂທີ່ຈະໃຊ້ກັບຖັນ CHAR ແລະ VARCHAR; [kbd]input[/kbd] - ຈຳກັດຄວາມຍາວຂອງ"
"ການປ້ອນໄດ້, [kbd]textarea[/kbd] - ສາມາດຂຶ້ນແຖວໃໝ່ໃນຖັນໄດ້."

#: libraries/classes/Config/Descriptions.php:101
msgid ""
"Use user-friendly editor for editing SQL queries (CodeMirror) with syntax "
"highlighting and line numbers."
msgstr ""
"ໃຊ້ເຄື່ອງມືແກ້ໄຂທີ່ໃຊ້ງ່າຍສຳລັບຄຳສັ່ງ SQL (CodeMirror) ພ້ອມການເນັ້ນໄວຍາກອນ ແລະ ເລກແຖວ."

#: libraries/classes/Config/Descriptions.php:106
msgid ""
"Find any errors in the query before executing it. Requires CodeMirror to be "
"enabled."
msgstr ""
"ກວດຫາຂໍ້ຜິດພາດໃນຄຳສັ່ງກ່ອນການປະມວນຜົນ. ຈຳເປັນຕ້ອງເປີດໃຊ້ CodeMirror ກ່ອນ."

#: libraries/classes/Config/Descriptions.php:110
msgid ""
"Defines the minimum size for input fields generated for CHAR and VARCHAR "
"columns."
msgstr "ກຳນົດຂະໜາດຂັ້ນຕ່ຳຂອງຫ້ອງປ້ອນຂໍ້ມູນສຳລັບຖັນ CHAR ແລະ VARCHAR."

#: libraries/classes/Config/Descriptions.php:114
msgid ""
"Defines the maximum size for input fields generated for CHAR and VARCHAR "
"columns."
msgstr "ກຳນົດຂະໜາດສູງສຸດຂອງຫ້ອງປ້ອນຂໍ້ມູນສຳລັບຖັນ CHAR ແລະ VARCHAR."

#: libraries/classes/Config/Descriptions.php:118
msgid ""
"Compress gzip exports on the fly without the need for much memory; if you "
"encounter problems with created gzip files disable this feature."
msgstr ""
"ບີບອັດ gzip ໃນຂະນະທີ່ສົ່ງອອກໂດຍບໍ່ໃຊ້ໜ່ວຍຄວາມຈຳຫຼາຍ; ຫາກພົບບັນຫາກັບໄຟລ໌ gzip ໃຫ້ປິດຟີເຈີນີ."

#: libraries/classes/Config/Descriptions.php:122
msgid ""
"Whether a warning (\"Are your really sure…\") should be displayed when "
"you're about to lose data."
msgstr ""
"ກຳນົດວ່າຈະໃຫ້ສະແດງຄຳເຕືອນ (\"ທ່ານແນ່ໃຈແທ້ບໍ່...\") ຫຼື ບໍ່ ເມື່ອທ່ານກຳລັງຈະເຮັດໃຫ້ຂໍ້ມູນສູນເສຍ."

#: libraries/classes/Config/Descriptions.php:126
msgid "Autocomplete of the table and column names in the SQL queries."
msgstr "ການເຕີມຊື່ຕາຕະລາງ ແລະ ຊື່ຖັນໃຫ້ອັດຕະໂນມັດໃນຄຳສັ່ງ SQL."

#: libraries/classes/Config/Descriptions.php:129
#: libraries/classes/Config/Descriptions.php:133
#: libraries/classes/Config/Descriptions.php:137
#: libraries/classes/Config/Descriptions.php:141
#: libraries/classes/Config/Descriptions.php:145
#: libraries/classes/Config/Descriptions.php:149
#: libraries/classes/Config/Descriptions.php:153
#: libraries/classes/Config/Descriptions.php:157
#: libraries/classes/Config/Descriptions.php:161
msgid ""
"Values for options list for default transformations. These will be "
"overwritten if transformation is filled in at table structure page."
msgstr ""
"ຄ່າສຳລັບລາຍການຕົວເລືອກໃນການແປງຄ່າເລີ່ມຕົ້ນ. ສິ່ງເຫຼົ່ານີ້ຈະຖືກຂຽນທັບ ຫາກມີການກຳນົດການແປງຄ່າໃນໜ້າໂຄງ"
"ສ້າງຕາຕະລາງ."

#: libraries/classes/Config/Descriptions.php:165
msgid ""
"Disable the table maintenance mass operations, like optimizing or repairing "
"the selected tables of a database."
msgstr ""
"ປິດໃຊ້ງານການບຳລຸງຮັກສາຕາຕະລາງແບບກຸ່ມ ເຊັ່ນ: ການປັບແຕ່ງ (Optimize) ຫຼື ຊ່ອມແຊມ (Repair) ຕາຕ"
"ະລາງທີ່ເລືອກ."

#: libraries/classes/Config/Descriptions.php:169
msgid ""
"Set the number of seconds a script is allowed to run ([kbd]0[/kbd] for no "
"limit)."
msgstr "ກຳນົດຈຳນວນວິນາທີທີ່ອະນຸຍາດໃຫ້ສະຄຣິບເຮັດວຽກ ([kbd]0[/kbd] ຄືບໍ່ຈຳກັດ)."

#: libraries/classes/Config/Descriptions.php:172
#: libraries/classes/Config/Descriptions.php:737
#: libraries/classes/Plugins/Export/ExportSql.php:348
msgid "Exclude definition of current user"
msgstr "ບໍ່ລວມຄຳນິຍາມ (Definition) ຂອງຜູ້ໃຊ້ປັດຈຸບັນ"

#: libraries/classes/Config/Descriptions.php:174
msgid ""
"Sort order for items in a foreign-key dropdown box; [kbd]content[/kbd] is "
"the referenced data, [kbd]id[/kbd] is the key value."
msgstr ""
"ລຳດັບການຈັດລຽງສຳລັບລາຍການໃນດຣອບດາວ Foreign-key; [kbd]content[/kbd] ແມ່ນຂໍ້ມູນທີ່ອ້າງອີ"
"ງ, [kbd]id[/kbd] ແມ່ນຄ່າຂອງຄີ."

#: libraries/classes/Config/Descriptions.php:178
msgid ""
"Specify browser's title bar text. Refer to [doc@faq6-27]documentation[/doc] "
"for magic strings that can be used to get special values."
msgstr ""
"ກຳນົດຂໍ້ຄວາມເທິງແຖບຫົວຂໍ້ຂອງບຣາວເຊີ. ເບິ່ງ [doc@faq6-27]documentation[/doc] ສຳລັບຂໍ້ຄວາມ "
"magic ທີ່ໃຊ້ເພື່ອດຶງຄ່າພິເສດ."

#: libraries/classes/Config/Descriptions.php:183
msgid ""
"Please note that phpMyAdmin is just a user interface and its features do not "
"limit MySQL."
msgstr ""
"ກະລຸນາຮັບຊາບວ່າ phpMyAdmin ເປັນພຽງສ່ວນຕິດຕໍ່ຜູ້ໃຊ້ ແລະ ຟີເຈີຂອງມັນບໍ່ໄດ້ຈຳກັດການເຮັດວຽກຂອງ "
"MySQL."

#: libraries/classes/Config/Descriptions.php:187
msgid ""
"Advanced server configuration, do not change these options unless you know "
"what they are for."
msgstr ""
"ການຕັ້ງຄ່າເຊີເວີຂັ້ນສູງ, ຫ້າມປ່ຽນຕົວເລືອກເຫຼົ່ານີ້ ເວັ້ນເສຍແຕ່ທ່ານຈະຮູ້ວ່າພວກມັນມີໄວ້ເພື່ອຫຍັງ."

#: libraries/classes/Config/Descriptions.php:191
msgid ""
"Configure phpMyAdmin configuration storage to gain access to additional "
"features, see [doc@linked-tables]phpMyAdmin configuration storage[/doc] in "
"documentation."
msgstr ""
"ຕັ້ງຄ່າບ່ອນເກັບຂໍ້ມູນ phpMyAdmin ເພື່ອເຂົ້າເຖິງຟີເຈີເພີ່ມເຕີມ, ເບິ່ງ [doc@linked-"
"tables]phpMyAdmin configuration storage[/doc] ໃນເອກະສານ."

#: libraries/classes/Config/Descriptions.php:196
msgid ""
"Tracking of changes made in database. Requires the phpMyAdmin configuration "
"storage."
msgstr ""
"ການຕິດຕາມການປ່ຽນແປງທີ່ເກີດຂຶ້ນໃນຖານຂໍ້ມູນ. ຈຳເປັນຕ້ອງມີບ່ອນເກັບຂໍ້ມູນການຕັ້ງຄ່າ phpMyAdmin."

#: libraries/classes/Config/Descriptions.php:200
msgid "Customize browse mode."
msgstr "ປັບແຕ່ງໂໝດການເບິ່ງ."

#: libraries/classes/Config/Descriptions.php:201
#: libraries/classes/Config/Descriptions.php:202
#: libraries/classes/Config/Descriptions.php:209
#: libraries/classes/Config/Descriptions.php:215
#: libraries/classes/Config/Descriptions.php:216
#: libraries/classes/Config/Descriptions.php:221
msgid "Customize default options."
msgstr "ປັບແຕ່ງຕົວເລືອກເລີ່ມຕົ້ນ."

#: libraries/classes/Config/Descriptions.php:203
msgid "Settings for phpMyAdmin developers."
msgstr "ການຕັ້ງຄ່າສຳລັບນັກພັດທະນາ phpMyAdmin."

#: libraries/classes/Config/Descriptions.php:204
msgid "Customize edit mode."
msgstr "ປັບແຕ່ງໂໝດການແກ້ໄຂ."

#: libraries/classes/Config/Descriptions.php:205
msgid "Customize default export options."
msgstr "ປັບແຕ່ງຕົວເລືອກການສົ່ງອອກເລີ່ມຕົ້ນ."

#: libraries/classes/Config/Descriptions.php:206
msgid "Set some commonly used options."
msgstr "ຕັ້ງຄ່າຕົວເລືອກທີ່ໃຊ້ເລື້ອຍໆ."

#: libraries/classes/Config/Descriptions.php:207
msgid "Customize default common import options."
msgstr "ປັບແຕ່ງຕົວເລືອກການນຳເຂົ້າທົ່ວໄປເລີ່ມຕົ້ນ."

#: libraries/classes/Config/Descriptions.php:208
msgid "Set import and export directories and compression options."
msgstr "ຕັ້ງຄ່າໂຟນເດີນຳເຂົ້າ/ສົ່ງອອກ ແລະ ຕົວເລືອກການບີບອັດ."

#: libraries/classes/Config/Descriptions.php:210
msgid "Databases display options."
msgstr "ຕົວເລືອກການສະແດງຜົນຖານຂໍ້ມູນ."

#: libraries/classes/Config/Descriptions.php:211
msgid "Customize appearance of the navigation panel."
msgstr "ປັບແຕ່ງຮູບລັກສະນະຂອງແຜງນຳທາງ."

#: libraries/classes/Config/Descriptions.php:212
msgid "Customize the navigation tree."
msgstr "ປັບແຕ່ງຕົ້ນໄມ້ນຳທາງ."

#: libraries/classes/Config/Descriptions.php:213
msgid "Servers display options."
msgstr "ຕົວເລືອກການສະແດງຜົນເຊີເວີ."

#: libraries/classes/Config/Descriptions.php:214
msgid "Tables display options."
msgstr "ຕົວເລືອກການສະແດງຜົນຕາຕະລາງ."

#: libraries/classes/Config/Descriptions.php:217
msgid "Settings that didn't fit anywhere else."
msgstr "ການຕັ້ງຄ່າທີ່ບໍ່ໄດ້ຢູ່ໃນໝວດໝູ່ອື່ນ."

#: libraries/classes/Config/Descriptions.php:218
msgid "Authentication settings."
msgstr "ການຕັ້ງຄ່າການຢືນຢັນຕົວຕົນ."

#: libraries/classes/Config/Descriptions.php:219
msgid "Enter server connection parameters."
msgstr "ປ້ອນພະລາມິເຕີການເຊື່ອມຕໍ່ເຊີເວີ."

#: libraries/classes/Config/Descriptions.php:220
msgid "Customize links shown in SQL Query boxes."
msgstr "ປັບແຕ່ງລິງທີ່ສະແດງໃນຫ້ອງຄຳສັ່ງ SQL."

#: libraries/classes/Config/Descriptions.php:222
msgid "SQL queries settings."
msgstr "ການຕັ້ງຄ່າຄຳສັ່ງ SQL."

#: libraries/classes/Config/Descriptions.php:223
msgid "Customize startup page."
msgstr "ປັບແຕ່ງໜ້າເລີ່ມຕົ້ນ."

#: libraries/classes/Config/Descriptions.php:224
msgid ""
"Choose which details to show in the database structure (list of tables)."
msgstr "ເລືອກລາຍລະອຽດທີ່ຈະສະແດງໃນໂຄງສ້າງຖານຂໍ້ມູນ (ລາຍຊື່ຕາຕະລາງ)."

#: libraries/classes/Config/Descriptions.php:225
msgid "Settings for the table structure (list of columns)."
msgstr "ການຕັ້ງຄ່າສຳລັບໂຄງສ້າງຕາຕະລາງ (ລາຍຊື່ຖັນ)."

#: libraries/classes/Config/Descriptions.php:226
msgid "Choose how you want tabs to work."
msgstr "ເລືອກວິທີການເຮັດວຽກຂອງແຖບ."

#: libraries/classes/Config/Descriptions.php:227
msgid "Customize text input fields."
msgstr "ປັບແຕ່ງຫ້ອງປ້ອນຂໍ້ຄວາມ."

#: libraries/classes/Config/Descriptions.php:228
msgid "Customize default options"
msgstr "ປັບແຕ່ງຕົວເລືອກເລີ່ມຕົ້ນ"

#: libraries/classes/Config/Descriptions.php:229
msgid "Disable some of the warnings shown by phpMyAdmin."
msgstr "ປິດຄຳເຕືອນບາງຢ່າງທີ່ສະແດງໂດຍ phpMyAdmin."

#: libraries/classes/Config/Descriptions.php:232
msgid "Enable gzip compression for import and export operations."
msgstr "ເປີດໃຊ້ການບີບອັດ gzip ສຳລັບການນຳເຂົ້າ ແລະ ສົ່ງອອກ."

#: libraries/classes/Config/Descriptions.php:236
msgid ""
"If enabled, phpMyAdmin continues computing multiple-statement queries even "
"if one of the queries failed."
msgstr ""
"ຫາກເປີດໃຊ້, phpMyAdmin ຈະປະມວນຜົນຄຳສັ່ງຕໍ່ໄປ ເຖິງແມ່ນວ່າບາງຄຳສັ່ງຈະລົ້ມເຫຼວກໍຕາມ."

#: libraries/classes/Config/Descriptions.php:240
msgid ""
"Allow interrupt of import in case script detects it is close to time limit. "
"This might be a good way to import large files, however it can break "
"transactions."
msgstr ""
"ອະນຸຍາດໃຫ້ຢຸດການນຳເຂົ້າຫາກສະຄຣິບກວດພົບວ່າໃກ້ຈະໝົດເວລາ. ນີ້ເປັນວິທີທີ່ດີໃນການນຳເຂົ້າໄຟລ໌ຂະໜາດໃຫຍ່, ແ"
"ຕ່ອາດເຮັດໃຫ້ທຸລະກຳ (Transaction) ຜິດພາດໄດ້."

#: libraries/classes/Config/Descriptions.php:245
msgid ""
"Default format; be aware that this list depends on location (database, "
"table) and only SQL is always available."
msgstr ""
"ຮູບແບບເລີ່ມຕົ້ນ; ຮັບຊາບວ່າລາຍການນີ້ຂຶ້ນກັບຕຳແໜ່ງ (ຖານຂໍ້ມູນ, ຕາຕະລາງ) ແລະ ມີພຽງ SQL ເທົ່ານັ້ນທີ່ມີໃຫ້ໃ"
"ຊ້ສະເໝີ."

#: libraries/classes/Config/Descriptions.php:248
#: libraries/classes/Config/Descriptions.php:249
msgid "Update data when duplicate keys found on import"
msgstr "ອັບເດດຂໍ້ມູນເມື່ອພົບຄີທີ່ຊ້ຳກັນໃນລະຫວ່າງການນຳເຂົ້າ"

#: libraries/classes/Config/Descriptions.php:250
msgid "Number of queries to skip from start."
msgstr "ຈຳນວນຄຳສັ່ງທີ່ຈະຂ້າມຕັ້ງແຕ່ເລີ່ມຕົ້ນ."

#: libraries/classes/Config/Descriptions.php:252
msgid ""
"If TRUE, logout deletes cookies for all servers; when set to FALSE, logout "
"only occurs for the current server. Setting this to FALSE makes it easy to "
"forget to log out from other servers when connected to multiple servers."
msgstr ""
"ຫາກເປັນ TRUE, ການອອກຈາກລະບົບຈະລຶບຄຸກກີ້ຂອງທຸກເຊີເວີ; ຫາກເປັນ FALSE ຈະອອກສະເພາະເຊີເວີປັດຈຸບັ"
"ນ. ການຕັ້ງເປັນ FALSE ອາດເຮັດໃຫ້ທ່ານລືມອອກຈາກລະບົບເຊີເວີອື່ນ ເມື່ອເຊື່ອມຕໍ່ຫຼາຍເຊີເວີ."

#: libraries/classes/Config/Descriptions.php:257
msgid ""
"Define whether the previous login should be recalled or not in [kbd]cookie[/"
"kbd] authentication mode."
msgstr ""
"ກຳນົດວ່າຈະໃຫ້ຈື່ຊື່ຜູ້ໃຊ້ທີ່ເຄີຍເຂົ້າສູ່ລະບົບກ່ອນໜ້ານີ້ ຫຼື ບໍ່ ໃນໂໝດ [kbd]cookie[/kbd]."

#: libraries/classes/Config/Descriptions.php:261
msgid ""
"Defines how long (in seconds) a login cookie should be stored in browser. "
"The default of 0 means that it will be kept for the existing session only, "
"and will be deleted as soon as you close the browser window. This is "
"recommended for non-trusted environments."
msgstr ""
"ກຳນົດໄລຍະເວລາ (ວິນາທີ) ທີ່ຈະເກັບຄຸກກີ້ການເຂົ້າສູ່ລະບົບໄວ້ໃນບຣາວເຊີ. ຄ່າ 0 ໝາຍເຖິງເກັບໄວ້ສະເພາະເຊດ"
"ຊັນປັດຈຸບັນ ແລະ ຈະຖືກລຶບທັນທີທີ່ປິດບຣາວເຊີ."

#: libraries/classes/Config/Descriptions.php:267
msgid "Maximum number of characters used when a SQL query is displayed."
msgstr "ຈຳນວນຕົວອັກສອນສູງສຸດທີ່ຈະໃຊ້ເມື່ອສະແດງຄຳສັ່ງ SQL."

#: libraries/classes/Config/Descriptions.php:270
msgid ""
"The number of items that can be displayed on each page on the first level of "
"the navigation tree."
msgstr "ຈຳນວນລາຍການທີ່ສາມາດສະແດງໄດ້ໃນແຕ່ລະໜ້າ ໃນລະດັບທຳອິດຂອງຕົ້ນໄມ້ນຳທາງ."

#: libraries/classes/Config/Descriptions.php:274
msgid ""
"The number of items that can be displayed on each page of the navigation "
"tree."
msgstr "ຈຳນວນລາຍການທີ່ສາມາດສະແດງໄດ້ໃນແຕ່ລະໜ້າຂອງຕົ້ນໄມ້ນຳທາງ."

#: libraries/classes/Config/Descriptions.php:277
msgid ""
"Number of rows displayed when browsing a result set. If the result set "
"contains more rows, \"Previous\" and \"Next\" links will be shown."
msgstr ""
"ຈຳນວນແຖວທີ່ຈະສະແດງເມື່ອເບິ່ງຜົນລັດ. ຫາກຜົນລັດມີຫຼາຍກວ່ານີ້, ລິງ \"ກ່ອນໜ້າ\" ແລະ \"ຖັດໄປ\" ຈະສະແດ"
"ງຂຶ້ນ."

#: libraries/classes/Config/Descriptions.php:282
msgid ""
"The number of bytes a script is allowed to allocate, e.g. [kbd]32M[/kbd] "
"([kbd]-1[/kbd] for no limit and [kbd]0[/kbd] for no change)."
msgstr ""
"ຈຳນວນໄບຕ໌ທີ່ອະນຸຍາດໃຫ້ສະຄຣິບໃຊ້ງານ ເຊັ່ນ [kbd]32M[/kbd] ([kbd]-1[/kbd] ຄືບໍ່ຈຳກັດ ແລະ "
"[kbd]0[/kbd] ຄືບໍ່ມີການປ່ຽນແປງ)."

#: libraries/classes/Config/Descriptions.php:286
msgid "In the navigation panel, replaces the database tree with a selector"
msgstr "ໃນແຜງນຳທາງ, ແທນທີ່ຕົ້ນໄມ້ຖານຂໍ້ມູນດ້ວຍຕົວເລືອກ"

#: libraries/classes/Config/Descriptions.php:289
msgid "Link with main panel by highlighting the current database or table."
msgstr "ເຊື່ອມຕໍ່ກັບແຜງຫຼັກໂດຍການເນັ້ນຖານຂໍ້ມູນ ຫຼື ຕາຕະລາງປັດຈຸບັນ."

#: libraries/classes/Config/Descriptions.php:292
msgid ""
"Open the linked page in the main window ([code]main[/code]) or in a new one "
"([code]new[/code])."
msgstr ""
"ເປີດໜ້າເວັບທີ່ເຊື່ອມໂຍງໃນໜ້າຕ່າງຫຼັກ ([code]main[/code]) ຫຼື ໃນໜ້າຕ່າງໃໝ່ ([code]new[/code])."

#: libraries/classes/Config/Descriptions.php:296
msgid ""
"Defines the minimum number of items (tables, views, routines and events) to "
"display a filter box."
msgstr ""
"ກຳນົດຈຳນວນລາຍການຂັ້ນຕ່ຳ (ຕາຕະລາງ, View, Routine ແລະ Event) ເພື່ອໃຫ້ສະແດງຫ້ອງຄົ້ນຫາ."

#: libraries/classes/Config/Descriptions.php:300
msgid ""
"Group items in the navigation tree (determined by the separator defined in "
"the Databases and Tables tabs above)."
msgstr ""
"ຈັດກຸ່ມລາຍການໃນຕົ້ນໄມ້ນຳທາງ (ກຳນົດໂດຍຕົວຂັ້ນທີ່ລະບຸໃນແຖບຖານຂໍ້ມູນ ແລະ ຕາຕະລາງດ້ານເທິງ)."

#: libraries/classes/Config/Descriptions.php:304
msgid ""
"Whether to offer the possibility of tree expansion in the navigation panel."
msgstr "ກຳນົດວ່າຈະໃຫ້ມີການຂະຫຍາຍຕົ້ນໄມ້ໃນແຜງນຳທາງ ຫຼື ບໍ່."

#: libraries/classes/Config/Descriptions.php:307
msgid "Whether to show procedures under database in the navigation tree"
msgstr "ກຳນົດວ່າຈະໃຫ້ສະແດງ Procedure ພາຍໃຕ້ຖານຂໍ້ມູນໃນຕົ້ນໄມ້ນຳທາງ ຫຼື ບໍ່"

#: libraries/classes/Config/Descriptions.php:310
msgid "Whether to expand single database in the navigation tree automatically."
msgstr "ກຳນົດວ່າຈະໃຫ້ຂະຫຍາຍຖານຂໍ້ມູນດຽວໃນແຖວນຳທາງໂດຍອັດຕະໂນມັດຫຼືບໍ່."

#: libraries/classes/Config/Descriptions.php:312
msgid "Set to 0 to collapse navigation panel."
msgstr "ຕັ້ງເປັນ 0 ເພື່ອພັບແຜງນຳທາງ."

#: libraries/classes/Config/Descriptions.php:313
msgid "Show logo in navigation panel."
msgstr "ສະແດງໂລໂກ້ໃນແຜງນຳທາງ."

#: libraries/classes/Config/Descriptions.php:314
msgid "URL where logo in the navigation panel will point to."
msgstr "URL ທີ່ໂລໂກ້ໃນແຜງນຳທາງຈະລິງໄປຫາ."

#: libraries/classes/Config/Descriptions.php:315
msgid "Display server choice at the top of the navigation panel."
msgstr "ສະແດງຕົວເລືອກເຊີເວີທີ່ດ້ານເທິງຂອງແຜງນຳທາງ."

#: libraries/classes/Config/Descriptions.php:316
msgid "String that separates databases into different tree levels."
msgstr "ຂໍ້ຄວາມທີ່ໃຊ້ຂັ້ນຖານຂໍ້ມູນອອກເປັນລະດັບຕ່າງໆ ໃນຕົ້ນໄມ້."

#: libraries/classes/Config/Descriptions.php:317
msgid "String that separates tables into different tree levels."
msgstr "ຂໍ້ຄວາມທີ່ໃຊ້ຂັ້ນຕາຕະລາງອອກເປັນລະດັບຕ່າງໆ ໃນຕົ້ນໄມ້."

#: libraries/classes/Config/Descriptions.php:318
msgid "Highlight server under the mouse cursor."
msgstr "ເນັ້ນເຊີເວີທີ່ເມົາສ໌ຊີ້ຢູ່."

#: libraries/classes/Config/Descriptions.php:319
msgid "Whether to show tables under database in the navigation tree"
msgstr "ກຳນົດວ່າຈະໃຫ້ສະແດງຕາຕະລາງພາຍໃຕ້ຖານຂໍ້ມູນໃນຕົ້ນໄມ້ນຳທາງ ຫຼື ບໍ່"

#: libraries/classes/Config/Descriptions.php:320
msgid "Whether to show views under database in the navigation tree"
msgstr "ກຳນົດວ່າຈະໃຫ້ສະແດງ View ພາຍໃຕ້ຖານຂໍ້ມູນໃນຕົ້ນໄມ້ນຳທາງ ຫຼື ບໍ່"

#: libraries/classes/Config/Descriptions.php:321
msgid "Whether to show functions under database in the navigation tree"
msgstr "ກຳນົດວ່າຈະໃຫ້ສະແດງ Function ພາຍໃຕ້ຖານຂໍ້ມູນໃນຕົ້ນໄມ້ນຳທາງ ຫຼື ບໍ່"

#: libraries/classes/Config/Descriptions.php:322
msgid "Whether to show events under database in the navigation tree"
msgstr "ກຳນົດວ່າຈະໃຫ້ສະແດງ Event ພາຍໃຕ້ຖານຂໍ້ມູນໃນຕົ້ນໄມ້ນຳທາງ ຫຼື ບໍ່"

#: libraries/classes/Config/Descriptions.php:324
msgid ""
"[kbd]SMART[/kbd] - i.e. descending order for columns of type TIME, DATE, "
"DATETIME and TIMESTAMP, ascending order otherwise."
msgstr ""
"[kbd]SMART[/kbd] - ຄືການລຽງລຳດັບຈາກຫຼາຍຫາໜ້ອຍສຳລັບຄໍລຳປະເພດ TIME, DATE, DATETIME ແລ"
"ະ TIMESTAMP, ສ່ວນປະເພດອື່ນໆແມ່ນລຽງຈາກໜ້ອຍຫາຫຼາຍ."

#: libraries/classes/Config/Descriptions.php:328
msgid ""
"Disable the default warning that is displayed on the database details "
"Structure page if any of the required tables for the phpMyAdmin "
"configuration storage could not be found."
msgstr ""
"ປິດການແຈ້ງເຕືອນເລີ່ມຕົ້ນທີ່ຈະສະແດງໃນໜ້າໂຄງສ້າງຖານຂໍ້ມູນ ຫາກບໍ່ພົບຕາຕະລາງທີ່ຈຳເປັນສຳລັບການເກັບຂໍ້ມູນການ"
"ຕັ້ງຄ່າຂອງ phpMyAdmin."

#: libraries/classes/Config/Descriptions.php:333
msgid ""
"Disable the default warning that is displayed on the Structure page if "
"column names in a table are reserved MySQL words."
msgstr ""
"ປິດການແຈ້ງເຕືອນເລີ່ມຕົ້ນທີ່ຈະສະແດງໃນໜ້າໂຄງສ້າງ ຫາກຊື່ຄໍລຳໃນຕາຕະລາງເປັນຄຳສະຫງວນຂອງ MySQL."

#: libraries/classes/Config/Descriptions.php:337
msgid ""
"Enable if you want DB-based query history (requires phpMyAdmin configuration "
"storage). If disabled, this utilizes JS-routines to display query history "
"(lost by window close)."
msgstr ""
"ເປີດໃຊ້ງານຫາກທ່ານຕ້ອງການປະຫວັດການສັ່ງງານໂດຍໃຊ້ຖານຂໍ້ມູນ (ຕ້ອງມີບ່ອນເກັບຂໍ້ມູນການຕັ້ງຄ່າ "
"phpMyAdmin). ຫາກປິດໄວ້, ມັນຈະໃຊ້ JS-routines ເພື່ອສະແດງປະຫວັດການສັ່ງງານ (ເຊິ່ງຈະຫາຍໄປເມື່ອ"
"ປິດໜ້າຕ່າງ)."

#: libraries/classes/Config/Descriptions.php:342
msgid ""
"Sets the effective timezone; possibly different than the one from your "
"database server"
msgstr ""
"ກຳນົດເຂດເວລາທີ່ມີຜົນບັງຄັບໃຊ້; ອາດຈະແຕກຕ່າງຈາກເຂດເວລາຂອງເຊີເວີຖານຂໍ້ມູນຂອງທ່ານ"

#: libraries/classes/Config/Descriptions.php:346
msgid ""
"Leave blank for no [doc@bookmarks@]bookmark[/doc] support, suggested: "
"[kbd]pma__bookmark[/kbd]"
msgstr ""
"ປະຫວ່າງໄວ້ຫາກບໍ່ຕ້ອງການຮອງຮັບ [doc@bookmarks@]ບຸກມາກ[/doc], ແນະນຳ: "
"[kbd]pma__bookmark[/kbd]"

#: libraries/classes/Config/Descriptions.php:350
msgid ""
"Leave blank for no column comments/media types, suggested: "
"[kbd]pma__column_info[/kbd]."
msgstr ""
"ປະວ່າງໄວ້ຫາກບໍ່ຕ້ອງການໃຊ້ຄຳອະທິບາຍຄໍລຳ/ປະເພດມີເດຍ, ຄ່າທີ່ແນະນຳຄື: [kbd]pma__column_info[/"
"kbd]."

#: libraries/classes/Config/Descriptions.php:354
msgid ""
"A special MySQL user configured with limited permissions, more information "
"available on [doc@linked-tables]documentation[/doc]."
msgstr ""
"ຜູ້ໃຊ້ MySQL ພິເສດທີ່ຖືກຕັ້ງຄ່າໃຫ້ມີສິດຈຳກັດ, ເບິ່ງຂໍ້ມູນເພີ່ມເຕີມໄດ້ທີ່ [doc@linked-tables]ເອກະສານ[/"
"doc]."

#: libraries/classes/Config/Descriptions.php:358
msgid ""
"An alternate host to hold the configuration storage; leave blank to use the "
"already defined host."
msgstr ""
"ໂຮສສຳຮອງສຳລັບເກັບຂໍ້ມູນການຕັ້ງຄ່າ; ປະຫວ່າງໄວ້ເພື່ອໃຊ້ໂຮສທີ່ກຳນົດໄວ້ແລ້ວ."

#: libraries/classes/Config/Descriptions.php:362
msgid ""
"An alternate port to connect to the host that holds the configuration "
"storage; leave blank to use the default port, or the already defined port, "
"if the controlhost equals host."
msgstr ""
"ພອດສຳຮອງສຳລັບເຊື່ອມຕໍ່ກັບໂຮສທີ່ເກັບຂໍ້ມູນການຕັ້ງຄ່າ; ປະຫວ່າງໄວ້ເພື່ອໃຊ້ພອດເລີ່ມຕົ້ນ."

#: libraries/classes/Config/Descriptions.php:367
msgid ""
"More information on [a@https://github.com/phpmyadmin/phpmyadmin/"
"issues/8970]phpMyAdmin issue tracker[/a] and [a@https://bugs.mysql."
"com/19588]MySQL Bugs[/a]"
msgstr ""
"ຂໍ້ມູນເພີ່ມເຕີມທີ່ [a@https://github.com/phpmyadmin/phpmyadmin/issues/"
"8970]phpMyAdmin issue tracker[/a] ແລະ [a@https://bugs.mysql.com/19588]MySQL "
"Bugs[/a]"

#: libraries/classes/Config/Descriptions.php:371
msgid ""
"Leave blank for no SQL query history support, suggested: [kbd]pma__history[/"
"kbd]."
msgstr ""
"ປະຫວ່າງໄວ້ຫາກບໍ່ຕ້ອງການຮອງຮັບປະຫວັດຄຳສັ່ງ SQL, ແນະນຳ: [kbd]pma__history[/kbd]."

#: libraries/classes/Config/Descriptions.php:375
msgid ""
"Limits number of table preferences which are stored in database, the oldest "
"records are automatically removed."
msgstr ""
"ຈຳກັດຈຳນວນການຕັ້ງຄ່າຕາຕະລາງທີ່ຈະເກັບໄວ້ໃນຖານຂໍ້ມູນ, ລາຍການທີ່ເກົ່າທີ່ສຸດຈະຖືກລຶບອອກໂດຍອັດຕະໂນມັດ."

#: libraries/classes/Config/Descriptions.php:379
msgid ""
"Leave blank for no QBE saved searches support, suggested: "
"[kbd]pma__savedsearches[/kbd]."
msgstr ""
"ປະຫວ່າງໄວ້ຫາກບໍ່ຕ້ອງການຮອງຮັບການບັນທຶກການຄົ້ນຫາ QBE, ແນະນຳ: [kbd]pma__savedsearches[/"
"kbd]."

#: libraries/classes/Config/Descriptions.php:383
msgid ""
"Leave blank for no export template support, suggested: "
"[kbd]pma__export_templates[/kbd]."
msgstr ""
"ປະຫວ່າງໄວ້ຫາກບໍ່ຕ້ອງການຮອງຮັບແມ່ແບບການສົ່ງອອກ, ແນະນຳ: [kbd]pma__export_templates[/"
"kbd]."

#: libraries/classes/Config/Descriptions.php:387
msgid ""
"Leave blank for no central columns support, suggested: "
"[kbd]pma__central_columns[/kbd]."
msgstr ""
"ປະຫວ່າງໄວ້ຫາກບໍ່ຕ້ອງການຮອງຮັບຄໍລຳສ່ວນກາງ, ແນະນຳ: [kbd]pma__central_columns[/kbd]."

#: libraries/classes/Config/Descriptions.php:391
msgid ""
"You can use MySQL wildcard characters (% and _), escape them if you want to "
"use their literal instances, i.e. use [kbd]'my\\_db'[/kbd] and not "
"[kbd]'my_db'[/kbd]."
msgstr ""
"ທ່ານສາມາດໃຊ້ MySQL wildcard (% ແລະ _), ໃຊ້ escape ຫາກຕ້ອງການໃຊ້ຕົວອັກສອນນັ້ນແທ້ໆ ເຊັ່ນ: "
"[kbd]'my\\_db'[/kbd]."

#: libraries/classes/Config/Descriptions.php:396
msgid ""
"Leave blank for no PDF schema support, suggested: [kbd]pma__pdf_pages[/kbd]."
msgstr ""
"ປະຫວ່າງໄວ້ຫາກບໍ່ຕ້ອງການຮອງຮັບ PDF schema, ແນະນຳ: [kbd]pma__pdf_pages[/kbd]."

#: libraries/classes/Config/Descriptions.php:399
msgid ""
"Database used for relations, bookmarks, and PDF features. See [doc@linked-"
"tables]pmadb[/doc] for complete information. Leave blank for no support. "
"Suggested: [kbd]phpmyadmin[/kbd]."
msgstr ""
"ຖານຂໍ້ມູນທີ່ໃຊ້ສຳລັບຄວາມສຳພັນ, ບຸກມາກ ແລະ PDF. ເບິ່ງຂໍ້ມູນທີ່ [doc@linked-tables]pmadb[/"
"doc]. ແນະນຳ: [kbd]phpmyadmin[/kbd]."

#: libraries/classes/Config/Descriptions.php:404
msgid ""
"Leave blank for no \"persistent\" recently used tables across sessions, "
"suggested: [kbd]pma__recent[/kbd]."
msgstr ""
"ປະຫວ່າງໄວ້ຫາກບໍ່ຕ້ອງການຈື່ຕາຕະລາງທີ່ໃຊ້ລ້າສຸດຂ້າມເຊດຊັນ, ແນະນຳ: [kbd]pma__recent[/kbd]."

#: libraries/classes/Config/Descriptions.php:408
msgid ""
"Leave blank for no \"persistent\" favorite tables across sessions, "
"suggested: [kbd]pma__favorite[/kbd]."
msgstr ""
"ປະຫວ່າງໄວ້ຫາກບໍ່ຕ້ອງການຈື່ຕາຕະລາງທີ່ມັກຂ້າມເຊດຊັນ, ແນະນຳ: [kbd]pma__favorite[/kbd]."

#: libraries/classes/Config/Descriptions.php:412
msgid ""
"Leave blank for no [doc@relations@]relation-links[/doc] support, suggested: "
"[kbd]pma__relation[/kbd]."
msgstr ""
"ປະຫວ່າງໄວ້ຫາກບໍ່ຕ້ອງການຮອງຮັບ [doc@relations@]ລິ້ງຄວາມສຳພັນ[/doc], ແນະນຳ: "
"[kbd]pma__relation[/kbd]."

#: libraries/classes/Config/Descriptions.php:417
msgid ""
"See [doc@authentication-modes]authentication types[/doc] for an example."
msgstr "ເບິ່ງຕົວຢ່າງໄດ້ທີ່ [doc@authentication-modes]ປະເພດການກວດສອບສິດ[/doc]."

#: libraries/classes/Config/Descriptions.php:421
msgid ""
"Leave blank for no PDF schema support, suggested: [kbd]pma__table_coords[/"
"kbd]."
msgstr ""
"ປະຫວ່າງໄວ້ຫາກບໍ່ຕ້ອງການຮອງຮັບ PDF schema, ແນະນຳ: [kbd]pma__table_coords[/kbd]."

#: libraries/classes/Config/Descriptions.php:424
msgid ""
"Table to describe the display columns, leave blank for no support; "
"suggested: [kbd]pma__table_info[/kbd]."
msgstr "ຕາຕະລາງສຳລັບອະທິບາຍຄໍລຳການສະແດງຜົນ; ແນະນຳ: [kbd]pma__table_info[/kbd]."

#: libraries/classes/Config/Descriptions.php:428
msgid ""
"Leave blank for no \"persistent\" tables' UI preferences across sessions, "
"suggested: [kbd]pma__table_uiprefs[/kbd]."
msgstr ""
"ປະຫວ່າງໄວ້ຫາກບໍ່ຕ້ອງການຈື່ການຕັ້ງຄ່າ UI ຂອງຕາຕະລາງຂ້າມເຊດຊັນ, ແນະນຳ: "
"[kbd]pma__table_uiprefs[/kbd]."

#: libraries/classes/Config/Descriptions.php:432
msgid ""
"Whether a DROP DATABASE IF EXISTS statement will be added as first line to "
"the log when creating a database."
msgstr ""
"ກຳນົດວ່າຈະເພີ່ມຄຳສັ່ງ DROP DATABASE IF EXISTS ເປັນບັນທັດທຳອິດໃນລັອກເມື່ອສ້າງຖານຂໍ້ມູນຫຼືບໍ່."

#: libraries/classes/Config/Descriptions.php:436
msgid ""
"Whether a DROP TABLE IF EXISTS statement will be added as first line to the "
"log when creating a table."
msgstr ""
"ກຳນົດວ່າຈະເພີ່ມຄຳສັ່ງ DROP TABLE IF EXISTS ເປັນບັນທັດທຳອິດໃນລັອກເມື່ອສ້າງຕາຕະລາງຫຼືບໍ່."

#: libraries/classes/Config/Descriptions.php:440
msgid ""
"Whether a DROP VIEW IF EXISTS statement will be added as first line to the "
"log when creating a view."
msgstr ""
"ກຳນົດວ່າຈະເພີ່ມຄຳສັ່ງ DROP VIEW IF EXISTS ເປັນບັນທັດທຳອິດໃນລັອກເມື່ອສ້າງ View ຫຼືບໍ່."

#: libraries/classes/Config/Descriptions.php:444
msgid "Defines the list of statements the auto-creation uses for new versions."
msgstr "ກຳນົດລາຍການຄຳສັ່ງທີ່ການສ້າງເວີຊັນໃໝ່ອັດຕະໂນມັດຈະນຳໃຊ້."

#: libraries/classes/Config/Descriptions.php:447
msgid ""
"Leave blank for no SQL query tracking support, suggested: "
"[kbd]pma__tracking[/kbd]."
msgstr ""
"ປະຫວ່າງໄວ້ຫາກບໍ່ຕ້ອງການຮອງຮັບການຕິດຕາມຄຳສັ່ງ SQL, ແນະນຳ: [kbd]pma__tracking[/kbd]."

#: libraries/classes/Config/Descriptions.php:451
msgid ""
"Whether the tracking mechanism creates versions for tables and views "
"automatically."
msgstr "ກຳນົດວ່າລະບົບຕິດຕາມຈະສ້າງເວີຊັນສຳລັບຕາຕະລາງ ແລະ View ອັດຕະໂນມັດຫຼືບໍ່."

#: libraries/classes/Config/Descriptions.php:455
msgid ""
"Leave blank for no user preferences storage in database, suggested: "
"[kbd]pma__userconfig[/kbd]."
msgstr ""
"ປະຫວ່າງໄວ້ຫາກບໍ່ຕ້ອງການເກັບການຕັ້ງຄ່າຜູ້ໃຊ້ໃນຖານຂໍ້ມູນ, ແນະນຳ: [kbd]pma__userconfig[/kbd]."

#: libraries/classes/Config/Descriptions.php:459
msgid ""
"Both this table and the user groups table are required to enable the "
"configurable menus feature; leaving either one of them blank will disable "
"this feature, suggested: [kbd]pma__users[/kbd]."
msgstr ""
"ຕ້ອງມີທັງຕາຕະລາງນີ້ ແລະ ຕາຕະລາງກຸ່ມຜູ້ໃຊ້ເພື່ອເປີດໃຊ້ງານເມນູທີ່ປັບແຕ່ງໄດ້; ແນະນຳ: "
"[kbd]pma__users[/kbd]."

#: libraries/classes/Config/Descriptions.php:464
msgid ""
"Both this table and the users table are required to enable the configurable "
"menus feature; leaving either one of them blank will disable this feature, "
"suggested: [kbd]pma__usergroups[/kbd]."
msgstr ""
"ຕ້ອງມີທັງຕາຕະລາງນີ້ ແລະ ຕາຕະລາງຜູ້ໃຊ້ເພື່ອເປີດໃຊ້ງານເມນູທີ່ປັບແຕ່ງໄດ້; ແນະນຳ: "
"[kbd]pma__usergroups[/kbd]."

#: libraries/classes/Config/Descriptions.php:469
msgid ""
"Leave blank to disable the feature to hide and show navigation items, "
"suggested: [kbd]pma__navigationhiding[/kbd]."
msgstr ""
"ປະຫວ່າງໄວ້ເພື່ອປິດການໃຊ້ງານການເຊື່ອງ/ສະແດງລາຍການນຳທາງ, ແນະນຳ: "
"[kbd]pma__navigationhiding[/kbd]."

#: libraries/classes/Config/Descriptions.php:473
msgid ""
"A user-friendly description of this server. Leave blank to display the "
"hostname instead."
msgstr "ຄຳອະທິບາຍເຊີເວີນີ້ໃຫ້ເຂົ້າໃຈງ່າຍ. ປະຫວ່າງໄວ້ເພື່ອສະແດງຊື່ໂຮສແທນ."

#: libraries/classes/Config/Descriptions.php:476
msgid "Leave blank if not used."
msgstr "ປະຫວ່າງໄວ້ຫາກບໍ່ໄດ້ໃຊ້."

#: libraries/classes/Config/Descriptions.php:477
msgid "Leave blank for defaults."
msgstr "ປະຫວ່າງໄວ້ສຳລັບຄ່າເລີ່ມຕົ້ນ."

#: libraries/classes/Config/Descriptions.php:478
msgid "HTTP Basic Auth Realm name to display when doing HTTP Auth."
msgstr "ຊື່ Realm ຂອງ HTTP Basic Auth ທີ່ຈະສະແດງເມື່ອມີການກວດສອບສິດຜ່ານ HTTP."

#: libraries/classes/Config/Descriptions.php:479
msgid "Authentication method to use."
msgstr "ວິທີການກວດສອບສິດທີ່ຈະໃຊ້."

#: libraries/classes/Config/Descriptions.php:480
msgid "Compress connection to MySQL server."
msgstr "ບີບອັດການເຊື່ອມຕໍ່ກັບເຊີເວີ MySQL."

#: libraries/classes/Config/Descriptions.php:481
msgid "Hide databases matching regular expression (PCRE)."
msgstr "ເຊື່ອງຖານຂໍ້ມູນທີ່ກົງກັບ regular expression (PCRE)."

#: libraries/classes/Config/Descriptions.php:482
msgid "Hostname where MySQL server is running."
msgstr "ຊື່ໂຮສ (Hostname) ທີ່ເຊີເວີ MySQL ກຳລັງເຮັດວຽກ."

#: libraries/classes/Config/Descriptions.php:483
#: libraries/classes/Config/Descriptions.php:487
msgid "Leave empty if not using config auth."
msgstr "ປະຫວ່າງໄວ້ຫາກບໍ່ໄດ້ໃຊ້ config auth."

#: libraries/classes/Config/Descriptions.php:484
msgid "Port on which MySQL server is listening, leave empty for default."
msgstr "ພອດທີ່ເຊີເວີ MySQL ເປີດຮັບການເຊື່ອມຕໍ່, ປະຫວ່າງໄວ້ສຳລັບຄ່າເລີ່ມຕົ້ນ."

#: libraries/classes/Config/Descriptions.php:485
msgid "Socket on which MySQL server is listening, leave empty for default."
msgstr ""
"Socket ທີ່ເຊີເວີ MySQL ເປີດຮັບການເຊື່ອມຕໍ່, ປະຫວ່າງໄວ້ສຳລັບຄ່າເລີ່ມຕົ້ນ."

#: libraries/classes/Config/Descriptions.php:486
msgid "Enable SSL for connection to MySQL server."
msgstr "ເປີດໃຊ້ SSL ສຳລັບການເຊື່ອມຕໍ່ຫາເຊີເວີ MySQL."

#: libraries/classes/Config/Descriptions.php:489
msgid ""
"Please note that enabling this has no effect with [kbd]config[/kbd] "
"authentication mode because the password is hard coded in the configuration "
"file; this does not limit the ability to execute the same command directly."
msgstr ""
"ໝາຍເຫດ: ການເປີດໃຊ້ງານນີ້ບໍ່ມີຜົນກັບໂໝດ [kbd]config[/kbd] ເພາະລະຫັດຜ່ານຖືກຝັງໄວ້ໃນໄຟລ໌ຕັ້ງຄ່າແລ້"
"ວ."

#: libraries/classes/Config/Descriptions.php:494
msgid "Show or hide a column displaying the Creation timestamp for all tables."
msgstr "ສະແດງ ຫຼື ເຊື່ອງຄໍລຳທີ່ສະແດງເວລາທີ່ສ້າງສຳລັບທຸກຕາຕະລາງ."

#: libraries/classes/Config/Descriptions.php:497
msgid ""
"Show or hide a column displaying the Last update timestamp for all tables."
msgstr "ສະແດງ ຫຼື ເຊື່ອງຄໍລຳທີ່ສະແດງເວລາອັບເດດລ້າສຸດສຳລັບທຸກຕາຕະລາງ."

#: libraries/classes/Config/Descriptions.php:500
msgid ""
"Show or hide a column displaying the Last check timestamp for all tables."
msgstr "ສະແດງ ຫຼື ເຊື່ອງຄໍລຳທີ່ສະແດງເວລາກວດສອບລ້າສຸດສຳລັບທຸກຕາຕະລາງ."

#: libraries/classes/Config/Descriptions.php:503
msgid ""
"Defines whether or not type fields should be initially displayed in edit/"
"insert mode."
msgstr ""
"ກຳນົດວ່າຈະສະແດງຟີວປະເພດ (type) ໃນໂໝດແກ້ໄຂ/ເພີ່ມຂໍ້ມູນ ເປັນຄ່າເລີ່ມຕົ້ນຫຼືບໍ່."

#: libraries/classes/Config/Descriptions.php:507
msgid ""
"Shows link to [a@https://www.php.net/manual/en/function.phpinfo.php]phpinfo()"
"[/a] output."
msgstr ""
"ສະແດງລິ້ງໄປຫາໜ້າຜົນລັບຂອງ [a@https://www.php.net/manual/en/"
"function.phpinfo.php]phpinfo()[/a]."

#: libraries/classes/Config/Descriptions.php:510
msgid "Whether a user should be displayed a \"show all (rows)\" button."
msgstr "ກຳນົດວ່າຈະສະແດງປຸ່ມ \"ສະແດງທັງໝົດ (ແຖວ)\" ໃຫ້ຜູ້ໃຊ້ຫຼືບໍ່."

#: libraries/classes/Config/Descriptions.php:511
msgid "Show or hide a column displaying the comments for all tables."
msgstr "ສະແດງ ຫຼື ເເຊື່ອງຄໍລຳທີ່ສະແດງຄຳອະທິບາຍສຳລັບທຸກຕາຕະລາງ."

#: libraries/classes/Config/Descriptions.php:512
msgid "Show or hide a column displaying the charset for all tables."
msgstr "ສະແດງ ຫຼື ເຊື່ອງຄໍລຳທີ່ສະແດງຊຸດຕົວອັກສອນສຳລັບທຸກຕາຕະລາງ."

#: libraries/classes/Config/Descriptions.php:513
msgid "Display the function fields in edit/insert mode."
msgstr "ສະແດງຟີວຟັງຊັນໃນໂໝດແກ້ໄຂ/ເພີ່ມຂໍ້ມູນ."

#: libraries/classes/Config/Descriptions.php:514
msgid "Whether to show hint or not."
msgstr "ກຳນົດວ່າຈະສະແດງຄຳແນະນຳ (hint) ຫຼື ບໍ່."

#: libraries/classes/Config/Descriptions.php:515
msgid ""
"Defines whether SQL queries generated by phpMyAdmin should be displayed."
msgstr "ກຳນົດວ່າຈະສະແດງຄຳສັ່ງ SQL ທີ່ສ້າງໂດຍ phpMyAdmin ຫຼື ບໍ່."

#: libraries/classes/Config/Descriptions.php:516
msgid "Allow to display database and table statistics (e.g. space usage)."
msgstr "ອະນຸຍາດໃຫ້ສະແດງສະຖິຕິຂອງຖານຂໍ້ມູນ ແລະ ຕາຕະລາງ (ເຊັ່ນ: ການໃຊ້ເນື້ອທີ່)."

#: libraries/classes/Config/Descriptions.php:518
msgid ""
"Mark used tables and make it possible to show databases with locked tables."
msgstr ""
"ໝາຍຕາຕະລາງທີ່ຖືກໃຊ້ ແລະ ເຮັດໃຫ້ສາມາດສະແດງຖານຂໍ້ມູນທີ່ມີຕາຕະລາງທີ່ຖືກລັອກໄດ້."

#: libraries/classes/Config/Descriptions.php:521
msgid ""
"Disable the default warning that is displayed on the main page if Suhosin is "
"detected."
msgstr "ປິດການແຈ້ງເຕືອນເລີ່ມຕົ້ນທີ່ຈະສະແດງໃນໜ້າຫຼັກຫາກກວດພົບ Suhosin."

#: libraries/classes/Config/Descriptions.php:525
msgid ""
"Disable the default warning that is displayed on the main page if the value "
"of the PHP setting session.gc_maxlifetime is less than the value of "
"`LoginCookieValidity`."
msgstr ""
"ປິດການແຈ້ງເຕືອນເມື່ອຄ່າ session.gc_maxlifetime ຂອງ PHP ໜ້ອຍກວ່າ LoginCookieValidity."

#: libraries/classes/Config/Descriptions.php:530
msgid ""
"Textarea size (columns) in edit mode, this value will be emphasized for SQL "
"query textareas (*2)."
msgstr ""
"ຂະໜາດຂອງ Textarea (ຄໍລຳ) ໃນໂໝດແກ້ໄຂ, ຄ່ານີ້ຈະຖືກຄູນສອງສຳລັບ textarea ຂອງຄຳສັ່ງ SQL."

#: libraries/classes/Config/Descriptions.php:534
msgid ""
"Textarea size (rows) in edit mode, this value will be emphasized for SQL "
"query textareas (*2)."
msgstr ""
"ຂະໜາດຂອງ Textarea (ແຖວ) ໃນໂໝດແກ້ໄຂ, ຄ່ານີ້ຈະຖືກຄູນສອງສຳລັບ textarea ຂອງຄຳສັ່ງ SQL."

#: libraries/classes/Config/Descriptions.php:538
msgid ""
"Input proxies as [kbd]IP: trusted HTTP header[/kbd]. The following example "
"specifies that phpMyAdmin should trust a HTTP_X_FORWARDED_FOR (X-Forwarded-"
"For) header coming from the proxy 1.2.3.4:[br][kbd]1.2.3.4: "
"HTTP_X_FORWARDED_FOR[/kbd]."
msgstr ""
"ໃສ່ Proxy ເປັນ [kbd]IP: trusted HTTP header[/kbd]. ຕົວຢ່າງ: [kbd]1.2.3.4: "
"HTTP_X_FORWARDED_FOR[/kbd]."

#: libraries/classes/Config/Descriptions.php:544
msgid ""
"When disabled, users cannot set any of the options below, regardless of the "
"checkbox on the right."
msgstr "ເມື່ອປິດໄວ້, ຜູ້ໃຊ້ຈະບໍ່ສາມາດຕັ້ງຄ່າຕົວເລືອກຂ້າງລຸ່ມນີ້ໄດ້."

#: libraries/classes/Config/Descriptions.php:548
msgid ""
"The url of the proxy to be used when retrieving the information about the "
"latest version of phpMyAdmin or when submitting error reports. You need this "
"if the server where phpMyAdmin is installed does not have direct access to "
"the internet. The format is: \"hostname:portnumber\"."
msgstr ""
"URL ຂອງ Proxy ທີ່ຈະໃຊ້ໃນການດຶງຂໍ້ມູນເວີຊັນ ຫຼື ສົ່ງລາຍງານຂໍ້ຜິດພາດ. ໃຊ້ໃນກໍລະນີທີ່ເຊີເວີບໍ່ສາມາດເຊື່ອມຕໍ່ອິ"
"ນເຕີເນັດໄດ້ໂດຍກົງ. ຮູບແບບແມ່ນ: \"hostname:portnumber\"."

#: libraries/classes/Config/Descriptions.php:554
msgid ""
"The username for authenticating with the proxy. By default, no "
"authentication is performed. If a username is supplied, Basic Authentication "
"will be performed. No other types of authentication are currently supported."
msgstr "ຊື່ຜູ້ໃຊ້ສຳລັບການກວດສອບສິດກັບ Proxy."

#: libraries/classes/Config/Descriptions.php:560
msgid ""
"Queries are executed by pressing Enter (instead of Ctrl+Enter). New lines "
"will be inserted with Shift+Enter."
msgstr ""
"ປະມວນຜົນຄຳສັ່ງໂດຍການກົດ Enter (ແທນທີ່ Ctrl+Enter). ສ່ວນການຂຶ້ນບັນທັດໃໝ່ໃຫ້ກົດ Shift+Enter."

#: libraries/classes/Config/Descriptions.php:564
msgid ""
"Enable Zero Configuration mode which lets you setup phpMyAdmin configuration "
"storage tables automatically."
msgstr ""
"ເປີດໃຊ້ໂໝດ Zero Configuration ເພື່ອຕັ້ງຄ່າຕາຕະລາງເກັບຂໍ້ມູນຂອງ phpMyAdmin ໂດຍອັດຕະໂນມັດ."

#: libraries/classes/Config/Descriptions.php:567
msgid "Highlight selected rows."
msgstr "ເນັ້ນແຖວທີ່ຖືກເລືອກ."

#: libraries/classes/Config/Descriptions.php:568
msgid "Highlight row pointed by the mouse cursor."
msgstr "ເນັ້ນແຖວທີ່ເມົາສ໌ຊີ້ຢູ່."

#: libraries/classes/Config/Descriptions.php:569
msgid "Number of columns for CHAR/VARCHAR textareas."
msgstr "ຈຳນວນຖັນ (ຄວາມກວ້າງ) ສຳລັບ CHAR/VARCHAR textarea."

#: libraries/classes/Config/Descriptions.php:570
msgid "Number of rows for CHAR/VARCHAR textareas."
msgstr "ຈຳນວນແຖວ (ຄວາມສູງ) ສຳລັບ CHAR/VARCHAR textarea."

#: libraries/classes/Config/Descriptions.php:571
msgid ""
"Log SQL queries and their execution time, to be displayed in the console"
msgstr "ບັນທຶກຄຳສັ່ງ SQL ແລະ ເວລາທີ່ໃຊ້ປະມວນຜົນ ເພື່ອສະແດງໃນຄອນໂຊນ"

#: libraries/classes/Config/Descriptions.php:572
msgid "Tab that is displayed when entering a database."
msgstr "ແຖບທີ່ຈະສະແດງເມື່ອເຂົ້າໄປໃນຖານຂໍ້ມູນ."

#: libraries/classes/Config/Descriptions.php:573
msgid "Tab that is displayed when entering a server."
msgstr "ແຖບທີ່ຈະສະແດງເມື່ອເຂົ້າໄປໃນເຊີເວີ."

#: libraries/classes/Config/Descriptions.php:574
msgid "Tab that is displayed when entering a table."
msgstr "ແຖບທີ່ຈະສະແດງເມື່ອເຂົ້າໄປໃນຕາຕະລາງ."

#: libraries/classes/Config/Descriptions.php:575
msgid "Whether the table structure actions should be hidden."
msgstr "ກຳນົດວ່າຈະເຊື່ອງການກະທຳຕ່າງໆ ໃນໂຄງສ້າງຕາຕະລາງ ຫຼື ບໍ່."

#: libraries/classes/Config/Descriptions.php:576
msgid "Whether column comments should be shown in table structure view"
msgstr "ກຳນົດວ່າຈະໃຫ້ສະແດງຄຳອະທິບາຍຖັນໃນມຸມມອງໂຄງສ້າງຕາຕະລາງ ຫຼື ບໍ່"

#: libraries/classes/Config/Descriptions.php:577
msgid "Show server listing as a list instead of a drop down."
msgstr "ສະແດງລາຍຊື່ເຊີເວີເປັນລາຍການ ແທນທີ່ຈະເປັນແບບດຣອບດາວ (Drop-down)."

#: libraries/classes/Config/Descriptions.php:578
msgid "A dropdown will be used if fewer items are present."
