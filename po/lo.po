msgstr "ລຶບຂໍ້ມູນການກຳນົດໂຄງສ້າງ (DDL) ທີ່ຕິດຕາມຢູ່ສຳເລັດແລ້ວ"

#: libraries/classes/Tracking.php:745
msgid "Tracking data manipulation successfully deleted"
msgstr "ລຶບຂໍ້ມູນການຈັດການຂໍ້ມູນ (DML) ທີ່ຕິດຕາມຢູ່ສຳເລັດແລ້ວ"

#: libraries/classes/Tracking.php:799
msgid ""
"You can execute the dump by creating and using a temporary database. Please "
"ensure that you have the privileges to do so."
msgstr ""
"ທ່ານສາມາດປະມວນຜົນໄຟລ໌ດຳໄດ້ໂດຍການສ້າງ ແລະ ໃຊ້ຖານຂໍ້ມູນຊົ່ວຄາວ. ກະລຸນາກວດສອບວ່າທ່ານມີສິດໃນການເຮັ"
"ດສິ່ງນີ້."

#: libraries/classes/Tracking.php:803
msgid "Comment out these two lines if you do not need them."
msgstr "ໃສ່ເຄື່ອງໝາຍຄອມເມັ້ນ (Comment) ສອງແຖວນີ້ຖ້າທ່ານບໍ່ຕ້ອງການ."

#: libraries/classes/Tracking.php:813
msgid "SQL statements exported. Please copy the dump or execute it."
msgstr "ສົ່ງອອກຄຳສັ່ງ SQL ແລ້ວ. ກະລຸນາສຳເນົາໄຟລ໌ດຳ ຫຼື ປະມວນຜົນມັນ."

#: libraries/classes/Tracking.php:861
#, possible-php-format
msgid "Tracking report for table `%s`"
msgstr "ລາຍງານການຕິດຕາມສຳລັບຕາຕະລາງ `%s`"

#: libraries/classes/Tracking.php:891
#, possible-php-format
msgid "Tracking for %1$s was activated at version %2$s."
msgstr "ການຕິດຕາມສຳລັບ %1$s ຖືກເປີດໃຊ້ງານໃນເວີຊັນ %2$s."

#: libraries/classes/Tracking.php:894
#, possible-php-format
msgid "Tracking for %1$s was deactivated at version %2$s."
msgstr "ການຕິດຕາມສຳລັບ %1$s ຖືກປິດໃຊ້ງານໃນເວີຊັນ %2$s."

#: libraries/classes/Tracking.php:986
#, possible-php-format
msgid "Version %1$s of %2$s was deleted."
msgstr "ເວີຊັນ %1$s ຂອງ %2$s ຖືກລຶບແລ້ວ."

#: libraries/classes/Tracking.php:1017
#, possible-php-format
msgid "Version %1$s was created, tracking for %2$s is active."
msgstr "ເວີຊັນ %1$s ຖືກສ້າງແລ້ວ, ການຕິດຕາມສຳລັບ %2$s ກຳລັງເຮັດວຽກ."

#: libraries/classes/Tracking.php:1114 libraries/classes/Tracking.php:1258
#: templates/table/tracking/selectable_tables.twig:9
msgid "active"
msgstr "ເຮັດວຽກຢູ່"

#: libraries/classes/Tracking.php:1117 libraries/classes/Tracking.php:1253
#: templates/table/tracking/selectable_tables.twig:11
msgid "not active"
msgstr "ບໍ່ໄດ້ເຮັດວຽກ"

#: libraries/classes/Types.php:203
msgid ""
"A 1-byte integer, signed range is -128 to 127, unsigned range is 0 to 255"
msgstr ""
"ເລກຖ້ວນຂະໜາດ 1 ໄບຕ໌ (Byte), ມີເຄື່ອງໝາຍແຕ່ -128 ຫາ 127, ບໍ່ມີເຄື່ອງໝາຍແຕ່ 0 ຫາ 255"

#: libraries/classes/Types.php:208
msgid ""
"A 2-byte integer, signed range is -32,768 to 32,767, unsigned range is 0 to "
"65,535"
msgstr ""
"ເລກຖ້ວນຂະໜາດ 2 ໄບຕ໌ (Byte), ມີເຄື່ອງໝາຍແຕ່ -32,768 ຫາ 32,767, ບໍ່ມີເຄື່ອງໝາຍແຕ່ 0 ຫາ "
"65,535"

#: libraries/classes/Types.php:213
msgid ""
"A 3-byte integer, signed range is -8,388,608 to 8,388,607, unsigned range is "
"0 to 16,777,215"
msgstr ""
"ເລກຖ້ວນຂະໜາດ 3 ໄບຕ໌ (Byte), ມີເຄື່ອງໝາຍແຕ່ -8,388,608 ຫາ 8,388,607, ບໍ່ມີເຄື່ອງໝາຍແຕ່ 0 ຫ"
"າ 16,777,215"

#: libraries/classes/Types.php:218
msgid ""
"A 4-byte integer, signed range is -2,147,483,648 to 2,147,483,647, unsigned "
"range is 0 to 4,294,967,295"
msgstr ""
"ເລກຖ້ວນຂະໜາດ 4 ໄບຕ໌ (Byte), ມີເຄື່ອງໝາຍແຕ່ -2,147,483,648 ຫາ 2,147,483,647, ບໍ່ມີເຄື່ອງໝ"
"າຍແຕ່ 0 ຫາ 4,294,967,295"

#: libraries/classes/Types.php:224
msgid ""
"An 8-byte integer, signed range is -9,223,372,036,854,775,808 to "
"9,223,372,036,854,775,807, unsigned range is 0 to 18,446,744,073,709,551,615"
msgstr ""
"ເລກຖ້ວນຂະໜາດ 8 ໄບຕ໌ (Byte), ມີເຄື່ອງໝາຍແຕ່ -9,223,372,036,854,775,808 ຫາ "
"9,223,372,036,854,775,807, ບໍ່ມີເຄື່ອງໝາຍແຕ່ 0 ຫາ 18,446,744,073,709,551,615"

#: libraries/classes/Types.php:230
msgid ""
"A fixed-point number (M, D) - the maximum number of digits (M) is 65 "
"(default 10), the maximum number of decimals (D) is 30 (default 0)"
msgstr ""
"ເລກທົດສະນິຍົມຄົງທີ່ (M, D) - ຈຳນວນຕົວເລກສູງສຸດ (M) ແມ່ນ 65 (ຄ່າເລີ່ມຕົ້ນ 10), ຈຳນວນທົດສະນິຍົມສູງ"
"ສຸດ (D) ແມ່ນ 30 (ຄ່າເລີ່ມຕົ້ນ 0)"

#: libraries/classes/Types.php:236
msgid ""
"A small floating-point number, allowable values are -3.402823466E+38 to "
"-1.175494351E-38, 0, and 1.175494351E-38 to 3.402823466E+38"
msgstr ""
"ເລກທົດສະນິຍົມຂະໜາດນ້ອຍ, ຄ່າທີ່ຍອມຮັບໄດ້ແມ່ນ -3.402823466E+38 ຫາ -1.175494351E-38, 0, ແລ"
"ະ 1.175494351E-38 ຫາ 3.402823466E+38"

#: libraries/classes/Types.php:242
msgid ""
"A double-precision floating-point number, allowable values are "
"-1.7976931348623157E+308 to -2.2250738585072014E-308, 0, and "
"2.2250738585072014E-308 to 1.7976931348623157E+308"
msgstr ""
"ເລກທົດສະນິຍົມຄວາມລະອຽດສູງ (Double), ຄ່າທີ່ຍອມຮັບໄດ້ແມ່ນ -1.7976931348623157E+308 ຫາ -"
"2.2250738585072014E-308, 0, ແລະ 2.2250738585072014E-308 ຫາ "
"1.7976931348623157E+308"

#: libraries/classes/Types.php:248
msgid ""
"Synonym for DOUBLE (exception: in REAL_AS_FLOAT SQL mode it is a synonym for "
"FLOAT)"
msgstr ""
"ຊື່ເອີ້ນອື່ນຂອງ DOUBLE (ຍົກເວັ້ນ: ໃນໂໝດ REAL_AS_FLOAT ມັນຈະເປັນຊື່ເອີ້ນອື່ນຂອງ FLOAT)"

#: libraries/classes/Types.php:253
msgid ""
"A bit-field type (M), storing M of bits per value (default is 1, maximum is "
"64)"
msgstr ""
"ປະເພດບິດ (M), ເກັບຂໍ້ມູນ M ບິດ ຕໍ່ຄ່າ (ຄ່າເລີ່ມຕົ້ນແມ່ນ 1, ສູງສຸດແມ່ນ 64)"

#: libraries/classes/Types.php:258
msgid ""
"A synonym for TINYINT(1), a value of zero is considered false, nonzero "
"values are considered true"
msgstr "ຊື່ເອີ້ນອື່ນຂອງ TINYINT(1), ຄ່າສູນແມ່ນ False, ຄ່າອື່ນໆແມ່ນ True"

#: libraries/classes/Types.php:262
msgid "An alias for BIGINT UNSIGNED NOT NULL AUTO_INCREMENT UNIQUE"
msgstr "ຊື່ແທນສຳລັບ BIGINT UNSIGNED NOT NULL AUTO_INCREMENT UNIQUE"

#: libraries/classes/Types.php:265
#, possible-php-format
msgid "A date, supported range is %1$s to %2$s"
msgstr "ວັນທີ, ຊ່ວງທີ່ຮອງຮັບແມ່ນ %1$s ຫາ %2$s"

#: libraries/classes/Types.php:270
#, possible-php-format
msgid "A date and time combination, supported range is %1$s to %2$s"
msgstr "ວັນທີ ແລະ ເວລາ, ຊ່ວງທີ່ຮອງຮັບແມ່ນ %1$s ຫາ %2$s"

#: libraries/classes/Types.php:275
msgid ""
"A timestamp, range is 1970-01-01 00:00:01 UTC to 2038-01-09 03:14:07 UTC, "
"stored as the number of seconds since the epoch (1970-01-01 00:00:00 UTC)"
msgstr ""
"ເວລາ (Timestamp), ຊ່ວງແມ່ນ 1970-01-01 00:00:01 UTC ຫາ 2038-01-09 03:14:07 UTC, "
"ເກັບໃນຮູບແບບຈຳນວນວິນາທີນັບຕັ້ງແຕ່ປີ 1970"

#: libraries/classes/Types.php:281
#, possible-php-format
msgid "A time, range is %1$s to %2$s"
msgstr "ເວລາ, ຊ່ວງທີ່ຮອງຮັບແມ່ນ %1$s ຫາ %2$s"

#: libraries/classes/Types.php:285
msgid ""
"A year in four-digit (4, default) or two-digit (2) format, the allowable "
"values are 70 (1970) to 69 (2069) or 1901 to 2155 and 0000"
msgstr ""
"ປີ ໃນຮູບແບບສີ່ຫຼັກ (4, ເລີ່ມຕົ້ນ) ຫຼື ສອງຫຼັກ (2), ຄ່າທີ່ຍອມຮັບໄດ້ແມ່ນ 1901 ຫາ 2155 (ຫຼື 70 ຫາ 69) "
"ແລະ 0000"

#: libraries/classes/Types.php:291
msgid ""
"A fixed-length (0-255, default 1) string that is always right-padded with "
"spaces to the specified length when stored"
msgstr ""
"ຂໍ້ຄວາມຄວາມຍາວຄົງທີ່ (0-255, ເລີ່ມຕົ້ນ 1) ເຊິ່ງຈະຖືກຕື່ມຊ່ອງວ່າງທາງຂວາໃຫ້ຄົບຕາມຄວາມຍາວທີ່ກຳນົດເມື່ອບັ"
"ນທຶກ"

#: libraries/classes/Types.php:297
#, possible-php-format
msgid ""
"A variable-length (%s) string, the effective maximum length is subject to "
"the maximum row size"
msgstr "ຂໍ້ຄວາມຄວາມຍາວບໍ່ຄົງທີ່ (%s), ຄວາມຍາວສູງສຸດແມ່ນຂຶ້ນກັບຂະໜາດສູງສຸດຂອງແຖວ"

#: libraries/classes/Types.php:303
msgid ""
"A TEXT column with a maximum length of 255 (2^8 - 1) characters, stored with "
"a one-byte prefix indicating the length of the value in bytes"
msgstr ""
"ຄໍລຳ TEXT ທີ່ມີຄວາມຍາວສູງສຸດ 255 ຕົວອັກສອນ, ເກັບຂໍ້ມູນພ້ອມກັບຄຳນຳໜ້າ 1 ໄບຕ໌ ເພື່ອບອກຄວາມຍາວ"

#: libraries/classes/Types.php:309
msgid ""
"A TEXT column with a maximum length of 65,535 (2^16 - 1) characters, stored "
"with a two-byte prefix indicating the length of the value in bytes"
msgstr ""
"ຄໍລຳ TEXT ທີ່ມີຄວາມຍາວສູງສຸດ 65,535 ຕົວອັກສອນ, ເກັບຂໍ້ມູນພ້ອມກັບຄຳນຳໜ້າ 2 ໄບຕ໌ ເພື່ອບອກຄວາມຍາວ"

#: libraries/classes/Types.php:315
msgid ""
"A TEXT column with a maximum length of 16,777,215 (2^24 - 1) characters, "
"stored with a three-byte prefix indicating the length of the value in bytes"
msgstr ""
"ຄໍລຳ TEXT ທີ່ມີຄວາມຍາວສູງສຸດ 16,777,215 ຕົວອັກສອນ, ເກັບຂໍ້ມູນພ້ອມກັບຄຳນຳໜ້າ 3 ໄບຕ໌ ເພື່ອບອກຄວາມ"
"ຍາວ"

#: libraries/classes/Types.php:321
msgid ""
"A TEXT column with a maximum length of 4,294,967,295 or 4GiB (2^32 - 1) "
"characters, stored with a four-byte prefix indicating the length of the "
"value in bytes"
msgstr ""
"ຄໍລຳ TEXT ທີ່ມີຄວາມຍາວສູງສຸດ 4,294,967,295 ຕົວອັກສອນ (4GiB), ເກັບຂໍ້ມູນພ້ອມກັບຄຳນຳໜ້າ 4 ໄບຕ໌ "
"ເພື່ອບອກຄວາມຍາວ"

#: libraries/classes/Types.php:327
msgid ""
"Similar to the CHAR type, but stores binary byte strings rather than non-"
"binary character strings"
msgstr "ຄ້າຍຄືກັບປະເພດ CHAR, ແຕ່ເກັບໃນຮູບແບບໄບນະລີ (Binary) ແທນຂໍ້ຄວາມປົກກະຕິ"

#: libraries/classes/Types.php:332
msgid ""
"Similar to the VARCHAR type, but stores binary byte strings rather than non-"
"binary character strings"
msgstr ""
"ຄ້າຍຄືກັບປະເພດ VARCHAR, ແຕ່ເກັບໃນຮູບແບບໄບນະລີ (Binary) ແທນຂໍ້ຄວາມປົກກະຕິ"

#: libraries/classes/Types.php:337
msgid ""
"A BLOB column with a maximum length of 255 (2^8 - 1) bytes, stored with a "
"one-byte prefix indicating the length of the value"
msgstr ""
"ຄໍລຳ BLOB ທີ່ມີຄວາມຍາວສູງສຸດ 255 ໄບຕ໌, ເກັບຂໍ້ມູນພ້ອມກັບຄຳນຳໜ້າ 1 ໄບຕ໌ ເພື່ອບອກຄວາມຍາວ"

#: libraries/classes/Types.php:342
msgid ""
"A BLOB column with a maximum length of 16,777,215 (2^24 - 1) bytes, stored "
"with a three-byte prefix indicating the length of the value"
msgstr ""
"ຄໍລຳ BLOB ທີ່ມີຄວາມຍາວສູງສຸດ 16,777,215 ໄບຕ໌, ເກັບຂໍ້ມູນພ້ອມກັບຄຳນຳໜ້າ 3 ໄບຕ໌ ເພື່ອບອກຄວາມຍາວ"

#: libraries/classes/Types.php:348
msgid ""
"A BLOB column with a maximum length of 65,535 (2^16 - 1) bytes, stored with "
"a two-byte prefix indicating the length of the value"
msgstr ""
"ຄໍລຳ BLOB ທີ່ມີຄວາມຍາວສູງສຸດ 65,535 ໄບຕ໌, ເກັບຂໍ້ມູນພ້ອມກັບຄຳນຳໜ້າ 2 ໄບຕ໌ ເພື່ອບອກຄວາມຍາວ"

#: libraries/classes/Types.php:353
msgid ""
"A BLOB column with a maximum length of 4,294,967,295 or 4GiB (2^32 - 1) "
"bytes, stored with a four-byte prefix indicating the length of the value"
msgstr ""
"ຄໍລຳ BLOB ທີ່ມີຄວາມຍາວສູງສຸດ 4,294,967,295 ໄບຕ໌ (4GiB), ເກັບຂໍ້ມູນພ້ອມກັບຄຳນຳໜ້າ 4 ໄບຕ໌ ເພື່ອບ"
"ອກຄວາມຍາວ"

#: libraries/classes/Types.php:359
msgid ""
"An enumeration, chosen from the list of up to 65,535 values or the special "
"'' error value"
msgstr "ລາຍການຕົວເລືອກ (Enum), ເລືອກໄດ້ຈາກລາຍການທີ່ມີສູງສຸດ 65,535 ຄ່າ"

#: libraries/classes/Types.php:363
msgid "A single value chosen from a set of up to 64 members"
msgstr "ຄ່າດ່ຽວທີ່ເລືອກຈາກກຸ່ມສະມາຊິກທີ່ມີໄດ້ສູງສຸດ 64 ຄ່າ"

#: libraries/classes/Types.php:365
msgid "A type that can store a geometry of any type"
msgstr "ປະເພດທີ່ສາມາດເກັບຂໍ້ມູນເລຂາຄະນິດ (Geometry) ໄດ້ທຸກຮູບແບບ"

#: libraries/classes/Types.php:367
msgid "A point in 2-dimensional space"
msgstr "ຈຸດ (Point) ໃນພື້ນທີ່ 2 ມິຕິ"

