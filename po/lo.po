#: libraries/classes/Config/ServerConfigChecks.php:428
#, possible-php-format
msgid ""
"%1$sLogin cookie validity%2$s greater than %3$ssession.gc_maxlifetime%4$s "
"may cause random session invalidation (currently session.gc_maxlifetime is "
"%5$d)."
msgstr ""
"%1$sLogin cookie validity%2$s greater than %3$ssession.gc_maxlifetime%4$s "
"may cause random session invalidation (currently session.gc_maxlifetime is "
"%5$d).\"\n"
