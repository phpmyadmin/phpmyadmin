#: libraries/advisory_rules_generic.txt:49
msgid "Uptime below one day"
msgstr "ເວລາເຮັດວຽກຂອງລະບົບ (Uptime) ໜ້ອຍກວ່າໜຶ່ງວັນ"

#: libraries/advisory_rules_generic.txt:52
msgid "Uptime is less than 1 day, performance tuning may not be accurate."
msgstr "ເວລາເຮັດວຽກຂອງລະບົບໜ້ອຍກວ່າ 1 ວັນ, ການປັບແຕ່ງປະສິດທິພາບອາດຈະບໍ່ຊັດເຈນ."

#: libraries/advisory_rules_generic.txt:53
msgid "To have more accurate averages it is recommended to let the server run for longer than a day before running this analyzer"
msgstr ""
"ເພື່ອໃຫ້ໄດ້ຄ່າສະເລ່ຍທີ່ຊັດເຈນກວ່າ, ແນະນຳໃຫ້ປ່ອຍໃຫ້ເຊີເວີເຮັດວຽກດົນກວ່າໜຶ່ງວັນກ່ອນທີ່ຈະໃຊ້ຕົວວິເຄາະນີ້"

#: libraries/advisory_rules_generic.txt:54
#, php-format
msgid "The uptime is only %s"
msgstr "ເວລາເຮັດວຽກຂອງລະບົບແມ່ນພຽງແຕ່ %s"

#: libraries/advisory_rules_generic.txt:56
msgid "Questions below 1,000"
msgstr "ຄຳຖາມ (Questions) ຕ່ຳກວ່າ 1,000"

#: libraries/advisory_rules_generic.txt:59
msgid "Fewer than 1,000 questions have been run against this server. The recommendations may not be accurate."
msgstr ""
"ມີຄຳຖາມໜ້ອຍກວ່າ 1,000 ຄຳຖາມທີ່ຖືກສົ່ງມາຫາເຊີເວີນີ້. ຄຳແນະນຳອາດຈະບໍ່ຊັດເຈນ."

#: libraries/advisory_rules_generic.txt:60
msgid "Let the server run for a longer time until it has executed a greater amount of queries."
msgstr ""
"ປ່ອຍໃຫ້ເຊີເວີເຮັດວຽກດົນກວ່າເກົ່າ ຈົນກວ່າມັນຈະປະມວນຜົນຄຳສັ່ງສອບຖາມໄດ້ໃນຈຳນວນທີ່ຫຼາຍຂຶ້ນ."

#: libraries/advisory_rules_generic.txt:61
#, php-format
msgid "Current amount of Questions: %s"
msgstr "ຈຳນວນຄຳຖາມໃນປັດຈຸບັນ: %s"

#: libraries/advisory_rules_generic.txt:63
msgid "Percentage of slow queries"
msgstr "ເປີເຊັນຂອງຄຳສັ່ງສອບຖາມທີ່ຊ້າ"

#: libraries/advisory_rules_generic.txt:66
msgid "There is a lot of slow queries compared to the overall amount of Queries."
msgstr "ມີຄຳສັ່ງສອບຖາມທີ່ຊ້າເປັນຈຳນວນຫຼາຍ ເມື່ອທຽບກັບຈຳນວນຄຳສັ່ງສອບຖາມທັງໝົດ."

#: libraries/advisory_rules_generic.txt:67 libraries/advisory_rules_generic.txt:74
msgid "You might want to increase {long_query_time} or optimize the queries listed in the slow query log"
msgstr ""
"ທ່ານອາດຈະຕ້ອງການເພີ່ມຄ່າ {long_query_time} ຫຼື ປັບແຕ່ງຄຳສັ່ງສອບຖາມທີ່ມີຢູ່ໃນລັອກຄຳສັ່ງທີ່ຊ້າ (slow "
"query log)"

#: libraries/advisory_rules_generic.txt:68
#, php-format
msgid "The slow query rate should be below 5%%, your value is %s%%."
msgstr "ອັດຕາຄຳສັ່ງສອບຖາມທີ່ຊ້າຄວນຕ່ຳກວ່າ 5%%, ຄ່າຂອງທ່ານແມ່ນ %s%%."

#: libraries/advisory_rules_generic.txt:70
msgid "Slow query rate"
msgstr "ອັດຕາຄຳສັ່ງສອບຖາມທີ່ຊ້າ"

#: libraries/advisory_rules_generic.txt:73
msgid "There is a high percentage of slow queries compared to the server uptime."
msgstr "ມີເປີເຊັນຂອງຄຳສັ່ງສອບຖາມທີ່ຊ້າສູງ ເມື່ອທຽບກັບເວລາເຮັດວຽກຂອງເຊີເວີ."

#: libraries/advisory_rules_generic.txt:75
#, php-format
msgid "You have a slow query rate of %s per hour, you should have less than 1%% per hour."
msgstr ""
"ທ່ານມີອັດຕາຄຳສັ່ງສອບຖາມທີ່ຊ້າ %s ຕໍ່ຊົ່ວໂມງ, ທ່ານຄວນມີຕ່ຳກວ່າ 1%% ຕໍ່ຊົ່ວໂມງ."

#: libraries/advisory_rules_generic.txt:77
msgid "Long query time"
msgstr "ເວລາຄຳສັ່ງສອບຖາມທີ່ດົນ"

#: libraries/advisory_rules_generic.txt:80
msgid "{long_query_time} is set to 10 seconds or more, thus only slow queries that take above 10 seconds are logged."
msgstr ""
"{long_query_time} ຖືກຕັ້ງໄວ້ທີ່ 10 ວິນາທີ ຫຼື ຫຼາຍກວ່າ, ດັ່ງນັ້ນສະເພາະຄຳສັ່ງສອບຖາມທີ່ຊ້າກວ່າ 10 ວິນາ"
"ທີ ຈຶ່ງຈະຖືກບັນທຶກລັອກ."

#: libraries/advisory_rules_generic.txt:81
msgid "It is suggested to set {long_query_time} to a lower value, depending on your environment. Usually a value of 1-5 seconds is suggested."
msgstr ""
"ແນະນຳໃຫ້ຕັ້ງຄ່າ {long_query_time} ໃຫ້ຕ່ຳລົງ, ຂຶ້ນກັບສະພາບແວດລ້ອມການໃຊ້ງານຂອງທ່ານ. ໂດຍທົ່ວໄປແ"
"ລ້ວແນະນຳໃຫ້ຕັ້ງເປັນ 1-5 ວິນາທີ."

#: libraries/advisory_rules_generic.txt:82
#, php-format
msgid "long_query_time is currently set to %ds."
msgstr "long_query_time ຖືກຕັ້ງໄວ້ທີ່ %ds ໃນປັດຈຸບັນ."

#: libraries/advisory_rules_generic.txt:84 libraries/advisory_rules_generic.txt:91
msgid "Slow query logging"
msgstr "ການບັນທຶກລັອກຄຳສັ່ງສອບຖາມທີ່ຊ້າ"

#: libraries/advisory_rules_generic.txt:87 libraries/advisory_rules_generic.txt:94
msgid "The slow query log is disabled."
msgstr "ການບັນທຶກລັອກຄຳສັ່ງສອບຖາມທີ່ຊ້າຖືກປິດໃຊ້ງານຢູ່."

#: libraries/advisory_rules_generic.txt:88
msgid "Enable slow query logging by setting {log_slow_queries} to 'ON'. This will help troubleshooting badly performing queries."
msgstr ""
"ເປີດໃຊ້ການບັນທຶກລັອກຄຳສັ່ງສອບຖາມທີ່ຊ້າໂດຍການຕັ້ງຄ່າ {log_slow_queries} ເປັນ 'ON'. ສິ່ງນີ້ຈະຊ່ວຍໃ"
"ນການແກ້ໄຂບັນຫາຄຳສັ່ງສອບຖາມທີ່ມີປະສິດທິພາບຕ່ຳ."

#: libraries/advisory_rules_generic.txt:89
msgid "log_slow_queries is set to 'OFF'"
msgstr "log_slow_queries ຖືກຕັ້ງເປັນ 'OFF'"

#: libraries/advisory_rules_generic.txt:95
msgid "Enable slow query logging by setting {slow_query_log} to 'ON'. This will help troubleshooting badly performing queries."
msgstr ""
"ເປີດໃຊ້ການບັນທຶກລັອກຄຳສັ່ງສອບຖາມທີ່ຊ້າໂດຍການຕັ້ງຄ່າ {slow_query_log} ເປັນ 'ON'. ສິ່ງນີ້ຈະຊ່ວຍໃນກ"
"ານແກ້ໄຂບັນຫາຄຳສັ່ງສອບຖາມທີ່ມີປະສິດທິພາບຕ່ຳ."

#: libraries/advisory_rules_generic.txt:96
msgid "slow_query_log is set to 'OFF'"
msgstr "slow_query_log ຖືກຕັ້ງເປັນ 'OFF'"

#: libraries/advisory_rules_generic.txt:100
msgid "Release Series"
msgstr "Release Series"

#: libraries/advisory_rules_generic.txt:103
msgid "The MySQL server version less than 5.1."
msgstr "ເວີຊັນຂອງເຊີເວີ MySQL ຕ່ຳກວ່າ 5.1."

#: libraries/advisory_rules_generic.txt:104
msgid "You should upgrade, as MySQL 5.1 has improved performance, and MySQL 5.5 even more so."
msgstr ""
"ທ່ານຄວນອັບເກຣດ, ເພາະວ່າ MySQL 5.1 ໄດ້ປັບປຸງປະສິດທິພາບດີຂຶ້ນ ແລະ MySQL 5.5 ກໍຍິ່ງດີກວ່າເກົ່າ."

#: libraries/advisory_rules_generic.txt:105 libraries/advisory_rules_generic.txt:112 libraries/advisory_rules_generic.txt:119
#, php-format
msgid "Current version: %s"
msgstr "ເວີຊັນປັດຈຸບັນ: %s"

#: libraries/advisory_rules_generic.txt:107 libraries/advisory_rules_generic.txt:114
msgid "Minor Version"
msgstr "ເວີຊັນຍ່ອຍ"

#: libraries/advisory_rules_generic.txt:110
msgid "Version less than 5.1.30 (the first GA release of 5.1)."
msgstr "ເວີຊັນຕ່ຳກວ່າ 5.1.30 (ລຸ້ນ GA ທຳອິດຂອງ 5.1)."

#: libraries/advisory_rules_generic.txt:111
msgid "You should upgrade, as recent versions of MySQL 5.1 have improved performance and MySQL 5.5 even more so."
msgstr ""
"ທ່ານຄວນອັບເກຣດ, ເພາະວ່າ MySQL 5.1 ເວີຊັນຫຼ້າສຸດໄດ້ປັບປຸງປະສິດທິພາບດີຂຶ້ນ ແລະ MySQL 5.5 ກໍຍິ່ງດີກວ່"
"າເກົ່າ."

#: libraries/advisory_rules_generic.txt:117
msgid "Version less than 5.5.8 (the first GA release of 5.5)."
msgstr "ເວີຊັນຕ່ຳກວ່າ 5.5.8 (ລຸ້ນ GA ທຳອິດຂອງ 5.5)."

#: libraries/advisory_rules_generic.txt:118
msgid "You should upgrade, to a stable version of MySQL 5.5."
msgstr "ທ່ານຄວນອັບເກຣດເປັນ MySQL 5.5 ເວີຊັນທີ່ມີຄວາມສະຖຽນ."

#: libraries/advisory_rules_generic.txt:121 libraries/advisory_rules_generic.txt:128
msgid "Distribution"
msgstr "ການແຈກຢາຍ (Distribution)"

#: libraries/advisory_rules_generic.txt:124
msgid "Version is compiled from source, not a MySQL official binary."
msgstr ""
"ເວີຊັນນີ້ຖືກຄອມໄພລ໌ (compile) ຈາກຊອສໂຄດ, ບໍ່ແມ່ນໄຟລ໌ບາຍນາຣີທາງການຂອງ MySQL."

#: libraries/advisory_rules_generic.txt:125
msgid "If you did not compile from source, you may be using a package modified by a distribution. The MySQL manual only is accurate for official MySQL binaries, not any package distributions (such as RedHat, Debian/Ubuntu etc)."
msgstr ""
"ຖ້າທ່ານບໍ່ໄດ້ຄອມໄພລ໌ຈາກຊອສໂຄດ, ທ່ານອາດຈະໃຊ້ແພັກເກດທີ່ຖືກດັດແປງໂດຍຜູ້ແຈກຢາຍ. ຄູ່ມື MySQL ຈະຖືກຕ້ອງ"
"ສະເພາະກັບໄຟລ໌ບາຍນາຣີທາງການຂອງ MySQL ເທົ່ານັ້ນ, ບໍ່ແມ່ນແພັກເກດຈາກຜູ້ແຈກຢາຍອື່ນໆ (ເຊັ່ນ RedHat, "
"Debian/Ubuntu ແລະ ອື່ນໆ)."

#: libraries/advisory_rules_generic.txt:126
msgid "'source' found in version_comment"
msgstr "ພົບ 'source' ໃນ version_comment"

#: libraries/advisory_rules_generic.txt:131
msgid "The MySQL manual only is accurate for official MySQL binaries."
msgstr "ຄູ່ມື MySQL ຈະຖືກຕ້ອງສະເພາະກັບໄຟລ໌ບາຍນາຣີທາງການຂອງ MySQL ເທົ່ານັ້ນ."

#: libraries/advisory_rules_generic.txt:132
msgid "Percona documentation is at <a href=\"https://www.percona.com/software/documentation/\">https://www.percona.com/software/documentation/</a>"
msgstr ""
"ເອກະສານຂອງ Percona ຢູ່ທີ່ <a href=\"https://www.percona.com/software/"
"documentation/\">https://www.percona.com/software/documentation/</a>"

#: libraries/advisory_rules_generic.txt:133
msgid "'percona' found in version_comment"
msgstr "ພົບ 'percona' ໃນ version_comment"

#: libraries/advisory_rules_generic.txt:135
msgid "MySQL Architecture"
msgstr "ສະຖາປັດຕະຍະກຳ MySQL"

#: libraries/advisory_rules_generic.txt:138
msgid "MySQL is not compiled as a 64-bit package."
msgstr "MySQL ບໍ່ໄດ້ຖືກຄອມໄພລ໌ເປັນແພັກເກດ 64 ບິດ."

#: libraries/advisory_rules_generic.txt:139
msgid "Your memory capacity is above 3 GiB (assuming the Server is on localhost), so MySQL might not be able to access all of your memory. You might want to consider installing the 64-bit version of MySQL."
msgstr ""
"ຄວາມຈຳ (RAM) ຂອງທ່ານຫຼາຍກວ່າ 3 GiB (ສົມມຸດວ່າເຊີເວີຢູ່ localhost), ດັ່ງນັ້ນ MySQL ອາດຈະບໍ່ສາມ"
"າດເຂົ້າເຖິງຄວາມຈຳທັງໝົດຂອງທ່ານໄດ້. ທ່ານອາດຈະພິຈາລະນາຕິດຕັ້ງ MySQL ເວີຊັນ 64 ບິດ."

#: libraries/advisory_rules_generic.txt:140
#, php-format
msgid "Available memory on this host: %s"
msgstr "ຄວາມຈຳທີ່ມີໃຫ້ໃນໂຮສນີ້: %s"

#: libraries/advisory_rules_generic.txt:145
msgid "Query caching method"
msgstr "ວິທີການເຮັດແຄຊຄຳສັ່ງສອບຖາມ"

#: libraries/advisory_rules_generic.txt:148
msgid "Suboptimal caching method."
msgstr "ວິທີການເຮັດແຄຊຍັງບໍ່ດີເທົ່າທີ່ຄວນ."

#: libraries/advisory_rules_generic.txt:149
msgid "You are using the MySQL Query cache with a fairly high traffic database. It might be worth considering to use <a href=\"https://dev.mysql.com/doc/refman/5.5/en/ha-memcached.html\">memcached</a> instead of the MySQL Query cache, especially if you have multiple slaves."
msgstr ""
"ທ່ານກຳລັງໃຊ້ MySQL Query cache ກັບຖານຂໍ້ມູນທີ່ມີການຮັບສົ່ງຂໍ້ມູນຂ້ອນຂ້າງສູງ. ທ່ານອາດຈະພິຈາລະນາໃຊ້ "
"<a href=\"https://dev.mysql.com/doc/refman/5.5/en/ha-memcached.html\">"
"memcached</a> ແທນ MySQL Query cache, ໂດຍສະເພາະຖ້າທ່ານມີເຊີເວີລູກ (slaves) ຫຼາຍເຄື່ອງ."

#: libraries/advisory_rules_generic.txt:150
#, php-format
msgid "The query cache is enabled and the server receives %d queries per second. This rule fires if there is more than 100 queries per second."
msgstr ""
"Query cache ຖືກເປີດໃຊ້ງານ ແລະ ເຊີເວີໄດ້ຮັບ %d ຄຳສັ່ງສອບຖາມຕໍ່ວິນາທີ. ກົດເກນນີ້ຈະເຮັດວຽກຖ້າມີຫຼາຍກ"
"ວ່າ 100 ຄຳສັ່ງສອບຖາມຕໍ່ວິນາທີ."

#: libraries/advisory_rules_generic.txt:154
msgid "Percentage of sorts that cause temporary tables"
msgstr "ເປີເຊັນຂອງການຈັດລຽງທີ່ເຮັດໃຫ້ເກີດຕາຕະລາງຊົ່ວຄາວ"

#: libraries/advisory_rules_generic.txt:157 libraries/advisory_rules_generic.txt:164
msgid "Too many sorts are causing temporary tables."
msgstr "ການຈັດລຽງຫຼາຍເກີນໄປກຳລັງເຮັດໃຫ້ເກີດຕາຕະລາງຊົ່ວຄາວ."

#: libraries/advisory_rules_generic.txt:158 libraries/advisory_rules_generic.txt:165
msgid "Consider increasing {sort_buffer_size} and/or {read_rnd_buffer_size}, depending on your system memory limits."
msgstr ""
"ພິຈາລະນາເພີ່ມ {sort_buffer_size} ແລະ/ຫຼື {read_rnd_buffer_size}, ໂດຍຂຶ້ນກັບຂີດຈຳກັດຄວາມ"
"ຈຳຂອງລະບົບຂອງທ່ານ."

#: libraries/advisory_rules_generic.txt:159
#, php-format
msgid "%s%% of all sorts cause temporary tables, this value should be lower than 10%%."
msgstr ""
"%s%% ຂອງການຈັດລຽງທັງໝົດເຮັດໃຫ້ເກີດຕາຕະລາງຊົ່ວຄາວ, ຄ່ານີ້ຄວນຕ່ຳກວ່າ 10%%."

#: libraries/advisory_rules_generic.txt:161
msgid "Rate of sorts that cause temporary tables"
msgstr "ອັດຕາການຈັດລຽງທີ່ເຮັດໃຫ້ເກີດຕາຕະລາງຊົ່ວຄາວ"

#: libraries/advisory_rules_generic.txt:166
#, php-format
msgid "Temporary tables average: %s, this value should be less than 1 per hour."
msgstr "ຄ່າສະເລ່ຍຂອງຕາຕະລາງຊົ່ວຄາວ: %s, ຄ່ານີ້ຄວນຕ່ຳກວ່າ 1 ຕໍ່ຊົ່ວໂມງ."

#: libraries/advisory_rules_generic.txt:168
msgid "Sort rows"
msgstr "ຈັດລຽງແຖວ"

#: libraries/advisory_rules_generic.txt:171
msgid "There are lots of rows being sorted."
msgstr "ມີແຖວຈຳນວນຫຼາຍກຳລັງຖືກຈັດລຽງ."

#: libraries/advisory_rules_generic.txt:172
msgid "While there is nothing wrong with a high amount of row sorting, you might want to make sure that the queries which require a lot of sorting use indexed columns in the ORDER BY clause, as this will result in much faster sorting."
msgstr ""
"ເຖິງວ່າຈະບໍ່ມີຫຍັງຜິດປົກກະຕິກັບການຈັດລຽງແຖວຈຳນວນຫຼາຍ, ແຕ່ທ່ານອາດຈະຕ້ອງການກວດສອບໃຫ້ແນ່ໃຈວ່າຄຳສັ່ງສ"
"ອບຖາມທີ່ຕ້ອງມີການຈັດລຽງຫຼາຍນັ້ນ ໄດ້ໃຊ້ຄໍລຳທີ່ມີດັດສະນີໃນ ORDER BY ເພາະມັນຈະເຮັດໃຫ້ການຈັດລຽງໄວຂຶ້ນຫຼາ"
"ຍ."

#: libraries/advisory_rules_generic.txt:173
#, php-format
msgid "Sorted rows average: %s"
msgstr "ຄ່າສະເລ່ຍຂອງແຖວທີ່ຖືກຈັດລຽງ: %s"

#: libraries/advisory_rules_generic.txt:176
msgid "Rate of joins without indexes"
msgstr "ອັດຕາການ Join ໂດຍບໍ່ມີດັດສະນີ"

#: libraries/advisory_rules_generic.txt:179
msgid "There are too many joins without indexes."
msgstr "ມີການ Join ໂດຍບໍ່ມີດັດສະນີຫຼາຍເກີນໄປ."

#: libraries/advisory_rules_generic.txt:180
msgid "This means that joins are doing full table scans. Adding indexes for the columns being used in the join conditions will greatly speed up table joins."
msgstr ""
"ນີ້ໝາຍຄວາມວ່າການ Join ກຳລັງເຮັດການສະແກນຕາຕະລາງທັງໝົດ. ການເພີ່ມດັດສະນີສຳລັບຄໍລຳທີ່ໃຊ້ໃນເງື່ອນໄຂກ"
"ານ Join ຈະຊ່ວຍໃຫ້ການ Join ຕາຕະລາງໄວຂຶ້ນຢ່າງຫຼວງຫຼາຍ."

#: libraries/advisory_rules_generic.txt:181
#, php-format
msgid "Table joins average: %s, this value should be less than 1 per hour"
msgstr "ຄ່າສະເລ່ຍການ Join ຕາຕະລາງ: %s, ຄ່ານີ້ຄວນຕ່ຳກວ່າ 1 ຕໍ່ຊົ່ວໂມງ"

#: libraries/advisory_rules_generic.txt:183
msgid "Rate of reading first index entry"
msgstr "ອັດຕາການອ່ານຂໍ້ມູນດັດສະນີທຳອິດ"

#: libraries/advisory_rules_generic.txt:186
msgid "The rate of reading the first index entry is high."
msgstr "ອັດຕາການອ່ານຂໍ້ມູນດັດສະນີທຳອິດແມ່ນສູງ."

#: libraries/advisory_rules_generic.txt:187
msgid "This usually indicates frequent full index scans. Full index scans are faster than table scans but require lots of CPU cycles in big tables, if those tables that have or had high volumes of UPDATEs and DELETEs, running 'OPTIMIZE TABLE' might reduce the amount of and/or speed up full index scans. Other than that full index scans can only be reduced by rewriting queries."
msgstr ""
"ໂດຍປົກກະຕິແລ້ວມັນບົ່ງບອກເຖິງການສະແກນດັດສະນີທັງໝົດເລື້ອຍໆ. ການສະແກນດັດສະນີທັງໝົດແມ່ນໄວກວ່າການສະແກ"
"ນຕາຕະລາງທັງໝົດ ແຕ່ຕ້ອງໃຊ້ CPU ຫຼາຍໃນຕາຕະລາງຂະໜາດໃຫຍ່, ຖ້າຕາຕະລາງເຫຼົ່ານັ້ນມີການ UPDATE ແລະ "
"DELETE ເປັນຈຳນວນຫຼາຍ, ການໃຊ້ 'OPTIMIZE TABLE' ອາດຈະຊ່ວຍຫຼຸດ ແລະ/ຫຼື ເພີ່ມຄວາມໄວໃນການສະແ"
"ກນດັດສະນີທັງໝົດໄດ້. ນອກຈາກນັ້ນ, ການສະແກນດັດສະນີທັງໝົດສາມາດຫຼຸດຜ່ອນໄດ້ໂດຍການຂຽນຄຳສັ່ງສອບຖາມໃໝ່ເທົ່"
"ານັ້ນ."

#: libraries/advisory_rules_generic.txt:188
#, php-format
msgid "Index scans average: %s, this value should be less than 1 per hour"
msgstr "ຄ່າສະເລ່ຍການສະແກນດັດສະນີ: %s, ຄ່ານີ້ຄວນຕ່ຳກວ່າ 1 ຕໍ່ຊົ່ວໂມງ"

#: libraries/advisory_rules_generic.txt:190
msgid "Rate of reading fixed position"
msgstr "ອັດຕາການອ່ານຈາກຕຳແໜ່ງທີ່ຄົງທີ່"

#: libraries/advisory_rules_generic.txt:193
msgid "The rate of reading data from a fixed position is high."
msgstr "ອັດຕາການອ່ານຂໍ້ມູນຈາກຕຳແໜ່ງທີ່ຄົງທີ່ແມ່ນສູງ."

#: libraries/advisory_rules_generic.txt:194
msgid "This indicates that many queries need to sort results and/or do a full table scan, including join queries that do not use indexes. Add indexes where applicable."
msgstr ""
"ນີ້ບົ່ງບອກວ່າຄຳສັ່ງສອບຖາມຈຳນວນຫຼາຍຕ້ອງມີການຈັດລຽງຜົນໄດ້ຮັບ ແລະ/ຫຼື ເຮັດການສະແກນຕາຕະລາງທັງໝົດ, ລວ"
"ມທັງຄຳສັ່ງ Join ທີ່ບໍ່ໄດ້ໃຊ້ດັດສະນີ. ໃຫ້ເພີ່ມດັດສະນີໃນບ່ອນທີ່ເໝາະສົມ."

#: libraries/advisory_rules_generic.txt:195
#, php-format
msgid "Rate of reading fixed position average: %s, this value should be less than 1 per hour"
msgstr "ຄ່າສະເລ່ຍອັດຕາການອ່ານຕຳແໜ່ງທີ່ຄົງທີ່: %s, ຄ່ານີ້ຄວນຕ່ຳກວ່າ 1 ຕໍ່ຊົ່ວໂມງ"

#: libraries/advisory_rules_generic.txt:197
msgid "Rate of reading next table row"
msgstr "ອັດຕາການອ່ານແຖວຕໍ່ໄປຂອງຕາຕະລາງ"

#: libraries/advisory_rules_generic.txt:200
msgid "The rate of reading the next table row is high."
msgstr "ອັດຕາການອ່ານແຖວຕໍ່ໄປຂອງຕາຕະລາງແມ່ນສູງ."

#: libraries/advisory_rules_generic.txt:201
msgid "This indicates that many queries are doing full table scans. Add indexes where applicable."
msgstr ""
"ນີ້ບົ່ງບອກວ່າຄຳສັ່ງສອບຖາມຈຳນວນຫຼາຍກຳລັງເຮັດການສະແກນຕາຕະລາງທັງໝົດ. ໃຫ້ເພີ່ມດັດສະນີໃນບ່ອນທີ່ເໝາະສົມ."

#: libraries/advisory_rules_generic.txt:202
#, php-format
msgid "Rate of reading next table row: %s, this value should be less than 1 per hour"
msgstr "ອັດຕາການອ່ານແຖວຕໍ່ໄປຂອງຕາຕະລາງ: %s, ຄ່ານີ້ຄວນຕ່ຳກວ່າ 1 ຕໍ່ຊົ່ວໂມງ"

#: libraries/advisory_rules_generic.txt:205
msgid "Different tmp_table_size and max_heap_table_size"
msgstr "ຄ່າ tmp_table_size ແລະ max_heap_table_size ແຕກຕ່າງກັນ"

#: libraries/advisory_rules_generic.txt:208
msgid "{tmp_table_size} and {max_heap_table_size} are not the same."
msgstr "{tmp_table_size} ແລະ {max_heap_table_size} ບໍ່ເທົ່າກັນ."

#: libraries/advisory_rules_generic.txt:209
msgid "If you have deliberately changed one of either: The server uses the lower value of either to determine the maximum size of in-memory tables. So if you wish to increase the in-memory table limit you will have to increase the other value as well."
msgstr ""
"ຖ້າທ່ານເຈດຕະນາປ່ຽນແປງຄ່າໃດໜຶ່ງ: ເຊີເວີຈະໃຊ້ຄ່າທີ່ຕ່ຳກວ່າລະຫວ່າງສອງຄ່ານີ້ເພື່ອມັກຳນົດຂະໜາດສູງສຸດຂອງຕາຕ"
"ະລາງໃນໜ່ວຍຄວາມຈຳ. ດັ່ງນັ້ນ ຖ້າທ່ານຕ້ອງການເພີ່ມຂີດຈຳກັດຂອງຕາຕະລາງໃນໜ່ວຍຄວາມຈຳ ທ່ານຈະຕ້ອງເພີ່ມອີກ"
"ຄ່າໜຶ່ງນຳ."

#: libraries/advisory_rules_generic.txt:210
#, php-format
msgid "Current values are tmp_table_size: %s, max_heap_table_size: %s"
msgstr "ຄ່າປັດຈຸບັນແມ່ນ tmp_table_size: %s, max_heap_table_size: %s"

#: libraries/advisory_rules_generic.txt:212
msgid "Percentage of temp tables on disk"
msgstr "ເປີເຊັນຂອງຕາຕະລາງຊົ່ວຄາວໃນດິສກ໌"

#: libraries/advisory_rules_generic.txt:215 libraries/advisory_rules_generic.txt:222
msgid "Many temporary tables are being written to disk instead of being kept in memory."
msgstr "ມີຕາຕະລາງຊົ່ວຄາວຈຳນວນຫຼາຍຖືກຂຽນລົງດິສກ໌ ແທນທີ່ຈະຖືກເກັບໄວ້ໃນໜ່ວຍຄວາມຈຳ."

#: libraries/advisory_rules_generic.txt:216
msgid "Increasing {max_heap_table_size} and {tmp_table_size} might help. However some temporary tables are always being written to disk, independent of the value of these variables. To eliminate these you will have to rewrite your queries to avoid those conditions (Within a temporary table: Presence of a BLOB or TEXT column or presence of a column bigger than 512 bytes) as mentioned in the beginning of an <a href=\"https://www.facebook.com/note.php?note_id=10150111255065841&comments\">Article by the Pythian Group</a>"
msgstr ""
"ການເພີ່ມ {max_heap_table_size} ແລະ {tmp_table_size} ອາດຈະຊ່ວຍໄດ້. ແນວໃດກໍຕາມ ຕາຕະລ"
"າງຊົ່ວຄາວບາງຢ່າງກໍຈະຖືກຂຽນລົງດິສກ໌ສະເໝີ ໂດຍບໍ່ຂຶ້ນກັບຄ່າເຫຼົ່ານີ້. ເພື່ອກຳຈັດບັນຫານີ້ ທ່ານຈະຕ້ອງຂຽນຄຳສັ່ງສອ"
"ບຖາມໃໝ່ເພື່ອຫຼີກລ່ຽງເງື່ອນໄຂເຫຼົ່ານັ້ນ (ພາຍໃນຕາຕະລາງຊົ່ວຄາວ: ມີຄໍລຳ BLOB ຫຼື TEXT ຫຼື ມີຄໍລຳທີ່ມີຂະໜາດໃ"
"ຫຍ່ກວ່າ 512 ໄບຕ໌) ຕາມທີ່ໄດ້ລະບຸໄວ້ໃນ <a href=\"https://www.facebook.com/"
"note.php?note_id=10150111255065841&comments\">ບົດຄວາມໂດຍ Pythian Group</a>"

#: libraries/advisory_rules_generic.txt:217
#, php-format
msgid "%s%% of all temporary tables are being written to disk, this value should be below 25%%"
msgstr "%s%% ຂອງຕາຕະລາງຊົ່ວຄາວທັງໝົດຖືກຂຽນລົງດິສກ໌, ຄ່ານີ້ຄວນຕ່ຳກວ່າ 25%%"

#: libraries/advisory_rules_generic.txt:219
msgid "Temp disk rate"
msgstr "ອັດຕາການໃຊ້ດິສກ໌ສຳລັບຂໍ້ມູນຊົ່ວຄາວ"

#: libraries/advisory_rules_generic.txt:223
msgid "Increasing {max_heap_table_size} and {tmp_table_size} might help. However some temporary tables are always being written to disk, independent of the value of these variables. To eliminate these you will have to rewrite your queries to avoid those conditions (Within a temporary table: Presence of a BLOB or TEXT column or presence of a column bigger than 512 bytes) as mentioned in the <a href=\"https://dev.mysql.com/doc/refman/5.5/en/internal-temporary-tables.html\">MySQL Documentation</a>"
msgstr ""
"ການເພີ່ມ {max_heap_table_size} ແລະ {tmp_table_size} ອາດຈະຊ່ວຍໄດ້. ແນວໃດກໍຕາມ ຕາຕະລ"
"າງຊົ່ວຄາວບາງຢ່າງກໍຈະຖືກຂຽນລົງດິສກ໌ສະເໝີ ໂດຍບໍ່ຂຶ້ນກັບຄ່າເຫຼົ່ານີ້. ເພື່ອກຳຈັດບັນຫານີ້ ທ່ານຈະຕ້ອງຂຽນຄຳສັ່ງສອ"
"ບຖາມໃໝ່ເພື່ອຫຼີກລ່ຽງເງື່ອນໄຂເຫຼົ່ານັ້ນ (ພາຍໃນຕາຕະລາງຊົ່ວຄາວ: ມີຄໍລຳ BLOB ຫຼື TEXT ຫຼື ມີຄໍລຳທີ່ມີຂະໜາດໃ"
"ຫຍ່ກວ່າ 512 ໄບຕ໌) ຕາມທີ່ລະບຸໄວ້ໃນ <a href=\"https://dev.mysql.com/doc/refman/5.5/en/"
"internal-temporary-tables.html\">ເອກະສານ MySQL</a>"

#: libraries/advisory_rules_generic.txt:224
#, php-format
msgid "Rate of temporary tables being written to disk: %s, this value should be less than 1 per hour"
msgstr ""
"ອັດຕາຂອງຕາຕະລາງຊົ່ວຄາວທີ່ຖືກຂຽນລົງດິສກ໌: %s, ຄ່ານີ້ຄວນຕ່ຳກວ່າ 1 ຕໍ່ຊົ່ວໂມງ"

#: libraries/advisory_rules_generic.txt:228
msgid "MyISAM key buffer size"
msgstr "ຂະໜາດ MyISAM key buffer"

#: libraries/advisory_rules_generic.txt:231
msgid "Key buffer is not initialized. No MyISAM indexes will be cached."
msgstr "Key buffer ບໍ່ໄດ້ຖືກເລີ່ມຕົ້ນ. ຈະບໍ່ມີການແຄຊດັດສະນີ MyISAM."

#: libraries/advisory_rules_generic.txt:232
msgid "Set {key_buffer_size} depending on the size of your MyISAM indexes. 64M is a good start."
msgstr ""
"ຕັ້ງຄ່າ {key_buffer_size} ໂດຍຂຶ້ນກັບຂະໜາດດັດສະນີ MyISAM ຂອງທ່ານ. 64M ແມ່ນການເລີ່ມຕົ້ນທີ່ດີ."

#: libraries/advisory_rules_generic.txt:233
msgid "key_buffer_size is 0"
msgstr "key_buffer_size ແມ່ນ 0"

#: libraries/advisory_rules_generic.txt:235
#, php-format
msgid "Max %% MyISAM key buffer ever used"
msgstr "ເປີເຊັນສູງສຸດຂອງ MyISAM key buffer ທີ່ເຄີຍໃຊ້"

#: libraries/advisory_rules_generic.txt:238 libraries/advisory_rules_generic.txt:246
#, php-format
msgid "MyISAM key buffer (index cache) %% used is low."
msgstr "ເປີເຊັນການໃຊ້ MyISAM key buffer (index cache) ແມ່ນຕ່ຳ."

#: libraries/advisory_rules_generic.txt:239 libraries/advisory_rules_generic.txt:247
msgid "You may need to decrease the size of {key_buffer_size}, re-examine your tables to see if indexes have been removed, or examine queries and expectations about what indexes are being used."
msgstr ""
"ທ່ານອາດຈະຕ້ອງຫຼຸດຂະໜາດຂອງ {key_buffer_size}, ກວດສອບຕາຕະລາງຂອງທ່ານຄືນໃໝ່ວ່າມີດັດສະນີໃດຖືກລຶ"
"ບອອກບໍ່, ຫຼື ກວດສອບຄຳສັ່ງສອບຖາມ ແລະ ສິ່ງທີ່ຄາດຫວັງກ່ຽວກັບດັດສະນີທີ່ກຳລັງຖືກໃຊ້."

#: libraries/advisory_rules_generic.txt:240
#, php-format
msgid "max %% MyISAM key buffer ever used: %s%%, this value should be above 95%%"
msgstr ""
"ເປີເຊັນສູງສຸດຂອງ MyISAM key buffer ທີ່ເຄີຍໃຊ້: %s%%, ຄ່ານີ້ຄວນສູງກວ່າ 95%%"

#: libraries/advisory_rules_generic.txt:243
msgid "Percentage of MyISAM key buffer used"
msgstr "ເປີເຊັນຂອງ MyISAM key buffer ທີ່ຖືກໃຊ້"

#: libraries/advisory_rules_generic.txt:248
#, php-format
msgid "%% MyISAM key buffer used: %s%%, this value should be above 95%%"
msgstr "%% ຂອງ MyISAM key buffer ທີ່ຖືກໃຊ້: %s%%, ຄ່ານີ້ຄວນສູງກວ່າ 95%%"

#: libraries/advisory_rules_generic.txt:250
msgid "Percentage of index reads from memory"
msgstr "ເປີເຊັນຂອງການອ່ານດັດສະນີຈາກໜ່ວຍຄວາມຈຳ"

#: libraries/advisory_rules_generic.txt:253
#, php-format
msgid "The %% of indexes that use the MyISAM key buffer is low."
msgstr "ເປີເຊັນຂອງດັດສະນີທີ່ໃຊ້ MyISAM key buffer ແມ່ນຕ່ຳ."

#: libraries/advisory_rules_generic.txt:254
msgid "You may need to increase {key_buffer_size}."
msgstr "ທ່ານອາດຈະຕ້ອງເພີ່ມຄ່າ {key_buffer_size}."

#: libraries/advisory_rules_generic.txt:255
#, php-format
msgid "Index reads from memory: %s%%, this value should be above 95%%"
msgstr "ການອ່ານດັດສະນີຈາກໜ່ວຍຄວາມຈຳ: %s%%, ຄ່ານີ້ຄວນສູງກວ່າ 95%%"

#: libraries/advisory_rules_generic.txt:259
msgid "Rate of table open"
msgstr "ອັດຕາການເປີດຕາຕະລາງ"

#: libraries/advisory_rules_generic.txt:262
msgid "The rate of opening tables is high."
msgstr "ອັດຕາການເປີດຕາຕະລາງແມ່ນສູງ."

#: libraries/advisory_rules_generic.txt:263
msgid "Opening tables requires disk I/O which is costly. Increasing {table_open_cache} might avoid this."
msgstr ""
"ການເປີດຕາຕະລາງຕ້ອງໃຊ້ Disk I/O ເຊິ່ງມີຕົ້ນທຶນສູງ. ການເພີ່ມ {table_open_cache} ອາດຈະຊ່ວຍຫຼີກລ່"
"ຽງບັນຫານີ້ໄດ້."

#: libraries/advisory_rules_generic.txt:264
#, php-format
msgid "Opened table rate: %s, this value should be less than 10 per hour"
msgstr "ອັດຕາການເປີດຕາຕະລາງ: %s, ຄ່ານີ້ຄວນຕ່ຳກວ່າ 10 ຕໍ່ຊົ່ວໂມງ"

#: libraries/advisory_rules_generic.txt:266
msgid "Percentage of used open files limit"
msgstr "ເປີເຊັນຂອງການໃຊ້ຂີດຈຳກັດການເປີດໄຟລ໌"

#: libraries/advisory_rules_generic.txt:269
msgid "The number of open files is approaching the max number of open files.  You may get a \"Too many open files\" error."
msgstr ""
"ຈຳນວນການເປີດໄຟລ໌ກຳລັງເຂົ້າໃກ້ຈຳນວນສູງສຸດ. ທ່ານອາດຈະໄດ້ຮັບຂໍ້ຜິດພາດ \"Too many open files\"."

#: libraries/advisory_rules_generic.txt:270 libraries/advisory_rules_generic.txt:277
msgid "Consider increasing {open_files_limit}, and check the error log when restarting after changing {open_files_limit}."
msgstr ""
"ພິຈາລະນາເພີ່ມ {open_files_limit}, ແລະ ກວດສອບ error log ເມື່ອເຮັດການຣີສະຕາດຫຼັງຈາກປ່ຽນຄ່"
"າ {open_files_limit}."

#: libraries/advisory_rules_generic.txt:271
#, php-format
msgid "The number of opened files is at %s%% of the limit. It should be below 85%%"
msgstr "ຈຳນວນໄຟລ໌ທີ່ຖືກເປີດຢູ່ທີ່ %s%% ຂອງຂີດຈຳກັດ. ມັນຄວນຈະຕ່ຳກວ່າ 85%%"

#: libraries/advisory_rules_generic.txt:273
msgid "Rate of open files"
msgstr "ອັດຕາການເປີດໄຟລ໌"

#: libraries/advisory_rules_generic.txt:276
msgid "The rate of opening files is high."
msgstr "ອັດຕາການເປີດໄຟລ໌ແມ່ນສູງ."

#: libraries/advisory_rules_generic.txt:278
#, php-format
msgid "Opened files rate: %s, this value should be less than 5 per hour"
msgstr "ອັດຕາການເປີດໄຟລ໌: %s, ຄ່ານີ້ຄວນຕ່ຳກວ່າ 5 ຕໍ່ຊົ່ວໂມງ"

#: libraries/advisory_rules_generic.txt:280
#, php-format
msgid "Immediate table locks %%"
msgstr "ເປີເຊັນການລັອກຕາຕະລາງທັນທີ %%"

#: libraries/advisory_rules_generic.txt:283 libraries/advisory_rules_generic.txt:290
msgid "Too many table locks were not granted immediately."
msgstr "ມີການລັອກຕາຕະລາງຫຼາຍເກີນໄປທີ່ບໍ່ໄດ້ຮັບການອະນຸຍາດທັນທີ."

#: libraries/advisory_rules_generic.txt:284 libraries/advisory_rules_generic.txt:291
msgid "Optimize queries and/or use InnoDB to reduce lock wait."
msgstr "ປັບແຕ່ງຄຳສັ່ງສອບຖາມ ແລະ/ຫຼື ໃຊ້ InnoDB ເພື່ອຫຼຸດເວລາລໍຖ້າການລັອກ."

#: libraries/advisory_rules_generic.txt:285
#, php-format
msgid "Immediate table locks: %s%%, this value should be above 95%%"
msgstr "ການລັອກຕາຕະລາງທັນທີ: %s%%, ຄ່ານີ້ຄວນສູງກວ່າ 95%%"

#: libraries/advisory_rules_generic.txt:287
msgid "Table lock wait rate"
msgstr "ອັດຕາການລໍຖ້າການລັອກຕາຕະລາງ"

#: libraries/advisory_rules_generic.txt:292
#, php-format
msgid "Table lock wait rate: %s, this value should be less than 1 per hour"
msgstr "ອັດຕາການລໍຖ້າການລັອກຕາຕະລາງ: %s, ຄ່ານີ້ຄວນຕ່ຳກວ່າ 1 ຕໍ່ຊົ່ວໂມງ"

#: libraries/advisory_rules_generic.txt:294
msgid "Thread cache"
msgstr "Thread cache"

#: libraries/advisory_rules_generic.txt:297
msgid "Thread cache is disabled, resulting in more overhead from new connections to MySQL."
msgstr ""
"Thread cache ຖືກປິດໃຊ້ງານ, ເຮັດໃຫ້ເກີດ overhead ຫຼາຍຂຶ້ນຈາກການເຊື່ອມຕໍ່ໃໝ່ຫາ MySQL."

#: libraries/advisory_rules_generic.txt:298
msgid "Enable the thread cache by setting {thread_cache_size} > 0."
msgstr "ເປີດໃຊ້ Thread cache ໂດຍການຕັ້ງຄ່າ {thread_cache_size} > 0."

#: libraries/advisory_rules_generic.txt:299
msgid "The thread cache is set to 0"
msgstr "Thread cache ຖືກຕັ້ງເປັນ 0"

#: libraries/advisory_rules_generic.txt:301
#, php-format
msgid "Thread cache hit rate %%"
msgstr "ເປີເຊັນ Thread cache hit rate %%"

#: libraries/advisory_rules_generic.txt:304
msgid "Thread cache is not efficient."
msgstr "Thread cache ບໍ່ມີປະສິດທິພາບ."

#: libraries/advisory_rules_generic.txt:305
msgid "Increase {thread_cache_size}."
msgstr "ເພີ່ມ {thread_cache_size}."

#: libraries/advisory_rules_generic.txt:306
#, php-format
msgid "Thread cache hitrate: %s%%, this value should be above 80%%"
msgstr "Thread cache hitrate: %s%%, ຄ່ານີ້ຄວນສູງກວ່າ 80%%"

#: libraries/advisory_rules_generic.txt:308
msgid "Threads that are slow to launch"
msgstr "ເທຣດທີ່ເລີ່ມຕົ້ນຊ້າ"

#: libraries/advisory_rules_generic.txt:311
msgid "There are too many threads that are slow to launch."
msgstr "ມີເທຣດຈຳນວນຫຼາຍເກີນໄປທີ່ເລີ່ມຕົ້ນຊ້າ."

#: libraries/advisory_rules_generic.txt:312
msgid "This generally happens in case of general system overload as it is pretty simple operations. You might want to monitor your system load carefully."
msgstr ""
"ໂດຍທົ່ວໄປແລ້ວມັນຈະເກີດຂຶ້ນໃນກໍລະນີທີ່ລະບົບເຮັດວຽກໜັກເກີນໄປ ເພາະມັນເປັນການເຮັດວຽກທີ່ຂ້ອນຂ້າງງ່າຍດາຍ. "
"ທ່ານອາດຈະຕ້ອງການຕິດຕາມການເຮັດວຽກຂອງລະບົບຢ່າງລະມັດລະວັງ."

#: libraries/advisory_rules_generic.txt:313
#, php-format
msgid "%s thread(s) took longer than %s seconds to start, it should be 0"
msgstr "ມີ %s ເທຣດທີ່ໃຊ້ເວລາດົນກວ່າ %s ວິນາທີໃນການເລີ່ມຕົ້ນ, ມັນຄວນຈະເປັນ 0"

#: libraries/advisory_rules_generic.txt:315
msgid "Slow launch time"
msgstr "ເວລາການເລີ່ມຕົ້ນທີ່ຊ້າ"

#: libraries/advisory_rules_generic.txt:318
msgid "Slow_launch_time is above 2s."
msgstr "Slow_launch_time ສູງກວ່າ 2 ວິນາທີ."

#: libraries/advisory_rules_generic.txt:319
msgid "Set {slow_launch_time} to 1s or 2s to correctly count threads that are slow to launch."
msgstr ""
"ຕັ້ງຄ່າ {slow_launch_time} ເປັນ 1 ວິນາທີ ຫຼື 2 ວິນາທີ ເພື່ອນັບຈຳນວນເທຣດທີ່ເລີ່ມຕົ້ນຊ້າໃຫ້ຖືກຕ້ອງ."

#: libraries/advisory_rules_generic.txt:320
#, php-format
msgid "slow_launch_time is set to %s"
msgstr "slow_launch_time ຖືກຕັ້ງເປັນ %s"

#: libraries/advisory_rules_generic.txt:324
msgid "Percentage of used connections"
msgstr "ເປີເຊັນຂອງການເຊື່ອມຕໍ່ທີ່ຖືກໃຊ້"

#: libraries/advisory_rules_generic.txt:327
msgid "The maximum amount of used connections is getting close to the value of {max_connections}."
msgstr "ຈຳນວນການເຊື່ອມຕໍ່ສູງສຸດທີ່ຖືກໃຊ້ກຳລັງເຂົ້າໃກ້ຄ່າຂອງ {max_connections}."

#: libraries/advisory_rules_generic.txt:328
msgid "Increase {max_connections}, or decrease {wait_timeout} so that connections that do not close database handlers properly get killed sooner. Make sure the code closes database handlers properly."
msgstr ""
"ເພີ່ມ {max_connections}, ຫຼື ຫຼຸດ {wait_timeout} ເພື່ອໃຫ້ການເຊື່ອມຕໍ່ທີ່ບໍ່ໄດ້ປິດ database "
"handlers ຢ່າງຖືກຕ້ອງຖືກຍົກເລີກໄວຂຶ້ນ. ກວດສອບໃຫ້ແນ່ໃຈວ່າໂຄ້ດໄດ້ປິດ database handlers ຢ່າງເໝາະ"
"ສົມ."

#: libraries/advisory_rules_generic.txt:329
#, php-format
msgid "Max_used_connections is at %s%% of max_connections, it should be below 80%%"
msgstr ""
"Max_used_connections ຢູ່ທີ່ %s%% ຂອງ max_connections, ມັນຄວນຈະຕ່ຳກວ່າ 80%%"

#: libraries/advisory_rules_generic.txt:331
msgid "Percentage of aborted connections"
msgstr "ເປີເຊັນຂອງການເຊື່ອມຕໍ່ທີ່ຖືກຍົກເລີກ"

#: libraries/advisory_rules_generic.txt:334 libraries/advisory_rules_generic.txt:341
msgid "Too many connections are aborted."
msgstr "ມີການເຊື່ອມຕໍ່ຈຳນວນຫຼາຍເກີນໄປທີ່ຖືກຍົກເລີກ."

#: libraries/advisory_rules_generic.txt:335 libraries/advisory_rules_generic.txt:342
msgid "Connections are usually aborted when they cannot be authorized. <a href=\"https://www.percona.com/blog/2008/08/23/how-to-track-down-the-source-of-aborted_connects/\">This article</a> might help you track down the source."
msgstr ""
"ການເຊື່ອມຕໍ່ມັກຈະຖືກຍົກເລີກເມື່ອບໍ່ສາມາດກວດສອບສິດໄດ້. <a href=\"https://www.percona.com/"
"blog/2008/08/23/how-to-track-down-the-source-of-aborted_connects/\"><a "
"href=\"https://www.percona.com/blog/2008/08/23/how-to-track-down-the-source-"
"of-aborted_connects/\">ບົດຄວາມນີ້</a> ອາດຈະຊ່ວຍໃຫ້ທ່ານຕິດຕາມຫາສາເຫດໄດ້."

#: libraries/advisory_rules_generic.txt:336
#, php-format
msgid "%s%% of all connections are aborted. This value should be below 1%%"
msgstr "%s%% ຂອງການເຊື່ອມຕໍ່ທັງໝົດຖືກຍົກເລີກ. ຄ່ານີ້ຄວນຕ່ຳກວ່າ 1%%"

#: libraries/advisory_rules_generic.txt:338
msgid "Rate of aborted connections"
msgstr "ອັດຕາການເຊື່ອມຕໍ່ທີ່ຖືກຍົກເລີກ"

#: libraries/advisory_rules_generic.txt:343
#, php-format
msgid "Aborted connections rate is at %s, this value should be less than 1 per hour"
msgstr "ອັດຕາການເຊື່ອມຕໍ່ທີ່ຖືກຍົກເລີກຢູ່ທີ່ %s, ຄ່ານີ້ຄວນຕ່ຳກວ່າ 1 ຕໍ່ຊົ່ວໂມງ"

#: libraries/advisory_rules_generic.txt:345
msgid "Percentage of aborted clients"
msgstr "ເປີເຊັນຂອງໄຄລເອັນທ໌ (clients) ທີ່ຖືກຍົກເລີກ"

#: libraries/advisory_rules_generic.txt:348 libraries/advisory_rules_generic.txt:355
msgid "Too many clients are aborted."
msgstr "ມີໄຄລເອັນທ໌ຈຳນວນຫຼາຍເກີນໄປທີ່ຖືກຍົກເລີກ."

#: libraries/advisory_rules_generic.txt:349 libraries/advisory_rules_generic.txt:356
msgid "Clients are usually aborted when they did not close their connection to MySQL properly. This can be due to network issues or code not closing a database handler properly. Check your network and code."
msgstr ""
"ໄຄລເອັນທ໌ມັກຈະຖືກຍົກເລີກເມື່ອພວກເຂົາບໍ່ໄດ້ປິດການເຊື່ອມຕໍ່ກັບ MySQL ຢ່າງຖືກຕ້ອງ. ສິ່ງນີ້ອາດຈະເກີດຈາກບັນຫາ"
"ເຄືອຂ່າຍ ຫຼື ໂຄ້ດທີ່ບໍ່ໄດ້ປິດ database handler ຢ່າງຖືກຕ້ອງ. ໃຫ້ກວດສອບເຄືອຂ່າຍ ແລະ ໂຄ້ດຂອງທ່ານ."

#: libraries/advisory_rules_generic.txt:350
#, php-format
msgid "%s%% of all clients are aborted. This value should be below 2%%"
msgstr "%s%% ຂອງໄຄລເອັນທ໌ທັງໝົດຖືກຍົກເລີກ. ຄ່ານີ້ຄວນຕ່ຳກວ່າ 2%%"

#: libraries/advisory_rules_generic.txt:352
msgid "Rate of aborted clients"
msgstr "ອັດຕາຂອງໄຄລເອັນທ໌ທີ່ຖືກຍົກເລີກ"

#: libraries/advisory_rules_generic.txt:357
#, php-format
msgid "Aborted client rate is at %s, this value should be less than 1 per hour"
msgstr "ອັດຕາໄຄລເອັນທ໌ທີ່ຖືກຍົກເລີກຢູ່ທີ່ %s, ຄ່ານີ້ຄວນຕ່ຳກວ່າ 1 ຕໍ່ຊົ່ວໂມງ"

#: libraries/advisory_rules_generic.txt:361
msgid "Is InnoDB disabled?"
msgstr "InnoDB ຖືກປິດໃຊ້ງານຢູ່ບໍ່?"

#: libraries/advisory_rules_generic.txt:364
msgid "You do not have InnoDB enabled."
msgstr "ທ່ານບໍ່ໄດ້ເປີດໃຊ້ງານ InnoDB."

#: libraries/advisory_rules_generic.txt:365
msgid "InnoDB is usually the better choice for table engines."
msgstr "ໂດຍປົກກະຕິແລ້ວ InnoDB ແມ່ນທາງເລືອກທີ່ດີກວ່າສຳລັບ table engines."

#: libraries/advisory_rules_generic.txt:366
msgid "have_innodb is set to 'value'"
msgstr "have_innodb ຖືກຕັ້ງເປັນ 'value'"

#: libraries/advisory_rules_generic.txt:368
msgid "InnoDB log size"
msgstr "ຂະໜາດ InnoDB log"

#: libraries/advisory_rules_generic.txt:371
msgid "The InnoDB log file size is not an appropriate size, in relation to the InnoDB buffer pool."
msgstr "ຂະໜາດຂອງ InnoDB log file ບໍ່ເໝາະສົມ ເມື່ອທຽບກັບ InnoDB buffer pool."

#: libraries/advisory_rules_generic.txt:372
#, php-format
msgid "Especially on a system with a lot of writes to InnoDB tables you should set {innodb_log_file_size} to 25%% of {innodb_buffer_pool_size}. However the bigger this value, the longer the recovery time will be when database crashes, so this value should not be set much higher than 256 MiB. Please note however that you cannot simply change the value of this variable. You need to shutdown the server, remove the InnoDB log files, set the new value in my.cnf, start the server, then check the error logs if everything went fine. See also <a href=\"https://mysqldatabaseadministration.blogspot.com/2007/01/increase-innodblogfilesize-proper-way.html\">this blog entry</a>"
msgstr ""
"ໂດຍສະເພາະໃນລະບົບທີ່ມີການຂຽນລົງຕາຕະລາງ InnoDB ເປັນຈຳນວນຫຼາຍ ທ່ານຄວນຕັ້ງຄ່າ "
"{innodb_log_file_size} ເປັນ 25%% ຂອງ {innodb_buffer_pool_size}. ແນວໃດກໍຕາມ ຍິ່ງຄ່າ"
"ນີ້ໃຫຍ່ເທົ່າໃດ ເວລາໃນການກູ້ຄືນຂໍ້ມູນ (recovery time) ກໍຈະດົນຂຶ້ນເທົ່ານັ້ນເມື່ອຖານຂໍ້ມູນຂັດຂ້ອງ, ດັ່ງນັ້ນຄ່ານີ້"
"ບໍ່ຄວນຕັ້ງສູງກວ່າ 256 MiB ຫຼາຍເກີນໄປ. ກະລຸນາສັງເກດວ່າທ່ານບໍ່ສາມາດປ່ຽນຄ່າຂອງຕົວປ່ຽນນີ້ໄດ້ໂດຍກົງ. ທ່ານ"
"ຈຳເປັນຕ້ອງປິດເຊີເວີ, ລຶບໄຟລ໌ InnoDB log, ຕັ້ງຄ່າໃໝ່ໃນ my.cnf, ເລີ່ມຕົ້ນເຊີເວີໃໝ່, ແລ້ວກວດສອບ "
"error logs ວ່າທຸກຢ່າງປົກກະຕິບໍ່. ເບິ່ງເພີ່ມເຕີມໄດ້ທີ່ <a href=\"https://"
"mysqldatabaseadministration.blogspot.com/2007/01/increase-innodblogfilesize-"
"proper-way.html\">ບົດຄວາມນີ້</a>"

#: libraries/advisory_rules_generic.txt:373
#, php-format
msgid "Your InnoDB log size is at %s%% in relation to the InnoDB buffer pool size, it should not be below 20%%"
msgstr ""
"ຂະໜາດ InnoDB log ຂອງທ່ານຢູ່ທີ່ %s%% ເມື່ອທຽບກັບຂະໜາດ InnoDB buffer pool, ມັນບໍ່ຄວນຕ່ຳກວ່າ "
"20%%"

#: libraries/advisory_rules_generic.txt:375
msgid "Max InnoDB log size"
msgstr "ຂະໜາດ InnoDB log ສູງສຸດ"

#: libraries/advisory_rules_generic.txt:378
msgid "The InnoDB log file size is inadequately large."
msgstr "ຂະໜາດໄຟລ໌ InnoDB log ໃຫຍ່ເກີນຄວາມຈຳເປັນ."

#: libraries/advisory_rules_generic.txt:379
#, php-format
msgid "It is usually sufficient to set {innodb_log_file_size} to 25%% of the size of {innodb_buffer_pool_size}. A very big {innodb_log_file_size} slows down the recovery time after a database crash considerably. See also <a href=\"https://www.percona.com/blog/2006/07/03/choosing-proper-innodb_log_file_size/\">this Article</a>. You need to shutdown the server, remove the InnoDB log files, set the new value in my.cnf, start the server, then check the error logs if everything went fine. See also <a href=\"https://mysqldatabaseadministration.blogspot.com/2007/01/increase-innodblogfilesize-proper-way.html\">this blog entry</a>"
msgstr ""
"ໂດຍປົກກະຕິແລ້ວການຕັ້ງຄ່າ {innodb_log_file_size} ເປັນ 25%% ຂອງຂະໜາດ "
"{innodb_buffer_pool_size} ແມ່ນພຽງພໍແລ້ວ. {innodb_log_file_size} ທີ່ໃຫຍ່ຫຼາຍຈະເຮັດໃຫ້ເວ"
"ລາໃນການກູ້ຄືນຂໍ້ມູນຫຼັງຈາກຖານຂໍ້ມູນຂັດຂ້ອງຊ້າລົງຢ່າງຫຼວງຫຼາຍ. ເບິ່ງເພີ່ມເຕີມໄດ້ທີ່ <a href=\"https://"
"www.percona.com/blog/2006/07/03/choosing-proper-innodb_log_file_size/\">ບົດຄວາ"
"ມນີ້</a>. ທ່ານຈຳເປັນຕ້ອງປິດເຊີເວີ, ລຶບໄຟລ໌ InnoDB log, ຕັ້ງຄ່າໃໝ່ໃນ my.cnf, ເລີ່ມຕົ້ນເຊີເວີໃໝ່, ແລ້"
"ວກວດສອບ error logs ວ່າທຸກຢ່າງປົກກະຕິບໍ່."

#: libraries/advisory_rules_generic.txt:380
#, php-format
msgid "Your absolute InnoDB log size is %s MiB"
msgstr "ຂະໜາດ InnoDB log ທີ່ແນ່ນອນຂອງທ່ານແມ່ນ %s MiB"

#: libraries/advisory_rules_generic.txt:382
msgid "InnoDB buffer pool size"
msgstr "ຂະໜາດ InnoDB buffer pool"

#: libraries/advisory_rules_generic.txt:385
msgid "Your InnoDB buffer pool is fairly small."
msgstr "InnoDB buffer pool ຂອງທ່ານຂ້ອນຂ້າງນ້ອຍ."

#: libraries/advisory_rules_generic.txt:386
#, php-format
msgid "The InnoDB buffer pool has a profound impact on performance for InnoDB tables. Assign all your remaining memory to this buffer. For database servers that use solely InnoDB as storage engine and have no other services (e.g. a web server) running, you may set this as high as 80%% of your available memory. If that is not the case, you need to carefully assess the memory consumption of your other services and non-InnoDB-Tables and set this variable accordingly. If it is set too high, your system will start swapping, which decreases performance significantly. See also <a href=\"https://www.percona.com/blog/2007/11/03/choosing-innodb_buffer_pool_size/\">this article</a>"
msgstr ""
"InnoDB buffer pool ມີຜົນກະທົບຢ່າງຫຼວງຫຼາຍຕໍ່ປະສິດທິພາບຂອງຕາຕະລາງ InnoDB. ໃຫ້ກຳນົດຄວາມຈຳທີ່ເ"
"ຫຼືອທັງໝົດຂອງທ່ານໃຫ້ກັບບັບເຟີນີ້. ສຳລັບຖານຂໍ້ມູນເຊີເວີທີ່ໃຊ້ InnoDB ເປັນ storage engine ພຽງຢ່າງດຽວ "
"ແລະ ບໍ່ມີບໍລິການອື່ນໆ (ເຊັ່ນ ເວັບເຊີເວີ) ເຮັດວຽກຢູ່, ທ່ານອາດຈະຕັ້ງຄ່ານີ້ສູງເຖິງ 80%% ຂອງຄວາມຈຳທີ່ມີຢູ່. ຖ້"
"າບໍ່ແມ່ນແນວນັ້ນ, ທ່ານຈຳເປັນຕ້ອງປະເມີນການໃຊ້ຄວາມຈຳຂອງບໍລິການອື່ນໆ ແລະ ຕາຕະລາງທີ່ບໍ່ແມ່ນ InnoDB ຢ່າ"
"ງລະມັດລະວັງ ແລະ ຕັ້ງຄ່າຕົວປ່ຽນນີ້ໃຫ້ເໝາະສົມ. ຖ້າຕັ້ງໄວ້ສູງເກີນໄປ, ລະບົບຂອງທ່ານຈະເລີ່ມເຮັດ swapping "
"ເຊິ່ງເຮັດໃຫ້ປະສິດທິພາບຫຼຸດລົງຢ່າງຫຼວງຫຼາຍ."

#: libraries/advisory_rules_generic.txt:387
#, php-format
msgid "You are currently using %s%% of your memory for the InnoDB buffer pool. This rule fires if you are assigning less than 60%%, however this might be perfectly adequate for your system if you don't have much InnoDB tables or other services running on the same machine."
msgstr ""
"ໃນປັດຈຸບັນທ່ານກຳລັງໃຊ້ %s%% ຂອງຄວາມຈຳຂອງທ່ານສຳລັບ InnoDB buffer pool. ກົດເກນນີ້ຈະເຮັດວຽກຖ້"
"າທ່ານກຳນົດໄວ້ຕ່ຳກວ່າ 60%%, ແນວໃດກໍຕາມ ມັນອາດຈະພຽງພໍແລ້ວສຳລັບລະບົບຂອງທ່ານ ຖ້າທ່ານບໍ່ມີຕາຕະລາງ "
"InnoDB ຫຼາຍ ຫຼື ບໍ່ມີບໍລິການອື່ນໆທີ່ເຮັດວຽກຢູ່ໃນເຄື່ອງດຽວກັນ."

#: libraries/advisory_rules_generic.txt:391
msgid "MyISAM concurrent inserts"
msgstr "MyISAM concurrent inserts"

#: libraries/advisory_rules_generic.txt:394
msgid "Enable {concurrent_insert} by setting it to 1"
msgstr "ເປີດໃຊ້ {concurrent_insert} ໂດຍການຕັ້ງຄ່າເປັນ 1"

#: libraries/advisory_rules_generic.txt:395
msgid "Setting {concurrent_insert} to 1 reduces contention between readers and writers for a given table. See also <a href=\"https://dev.mysql.com/doc/refman/5.5/en/concurrent-inserts.html\">MySQL Documentation</a>"
msgstr ""
"ການຕັ້ງຄ່າ {concurrent_insert} ເປັນ 1 ຈະຊ່ວຍຫຼຸດຜ່ອນການຍາດແຍ່ງລະຫວ່າງຜູ້ອ່ານ ແລະ ຜູ້ຂຽນຂໍ້ມູນໃນ"
"ຕາຕະລາງ. ເບິ່ງເພີ່ມເຕີມໄດ້ທີ່ <a href=\"https://dev.mysql.com/doc/refman/5.5/en/"
"concurrent-inserts.html\">ເອກະສານ MySQL</a>"

#: libraries/advisory_rules_generic.txt:396
msgid "concurrent_insert is set to 0"
msgstr "concurrent_insert ຖືກຕັ້ງເປັນ 0"

#: libraries/advisory_rules_mysql_before80003.txt:10
msgid "Query cache disabled"
msgstr "Query cache ຖືກປິດໃຊ້ງານ"

#: libraries/advisory_rules_mysql_before80003.txt:13
msgid "The query cache is not enabled."
msgstr "Query cache ບໍ່ໄດ້ຖືກເປີດໃຊ້ງານ."

#: libraries/advisory_rules_mysql_before80003.txt:14
msgid "The query cache is known to greatly improve performance if configured correctly. Enable it by setting {query_cache_size} to a 2 digit MiB value and setting {query_cache_type} to 'ON'. <b>Note:</b> If you are using memcached, ignore this recommendation."
msgstr ""
"Query cache ເປັນທີ່ຮູ້ຈັກກັນດີວ່າມັນຊ່ວຍປັບປຸງປະສິດທິພາບໄດ້ຢ່າງຫຼວງຫຼາຍຖ້າຕັ້ງຄ່າຢ່າງຖືກຕ້ອງ. ເປີດໃຊ້ມັນໂດ"
"ຍການຕັ້ງຄ່າ {query_cache_size} ເປັນຄ່າ MiB ທີ່ມີ 2 ຫຼັກ ແລະ ຕັ້ງ {query_cache_type} ເປັນ "
"'ON'. <b>ໝາຍເຫດ:</b> ຖ້າທ່ານກຳລັງໃຊ້ memcached ໃຫ້ຂ້າມຄຳແນະນຳນີ້."

#: libraries/advisory_rules_mysql_before80003.txt:15
msgid "query_cache_size is set to 0 or query_cache_type is set to 'OFF'"
msgstr "query_cache_size ຖືກຕັ້ງເປັນ 0 ຫຼື query_cache_type ຖືກຕັ້ງເປັນ 'OFF'"

#: libraries/advisory_rules_mysql_before80003.txt:17
#, php-format
msgid "Query cache efficiency (%%)"
msgstr "ປະສິດທິພາບຂອງ Query cache (%%)"

#: libraries/advisory_rules_mysql_before80003.txt:20
msgid "Query cache not running efficiently, it has a low hit rate."
msgstr "Query cache ເຮັດວຽກບໍ່ມີປະສິດທິພາບ, ມັນມີອັດຕາການ hit ຕ່ຳ."

#: libraries/advisory_rules_mysql_before80003.txt:21
msgid "Consider increasing {query_cache_limit}."
msgstr "ພິຈາລະນາເພີ່ມ {query_cache_limit}."

#: libraries/advisory_rules_mysql_before80003.txt:22
#, php-format
msgid "The current query cache hit rate of %s%% is below 20%%"
msgstr "ອັດຕາການ hit ຂອງ query cache ໃນປັດຈຸບັນແມ່ນ %s%% ເຊິ່ງຕ່ຳກວ່າ 20%%"

#: libraries/advisory_rules_mysql_before80003.txt:24
msgid "Query Cache usage"
msgstr "ການໃຊ້ Query Cache"

#: libraries/advisory_rules_mysql_before80003.txt:27
#, php-format
msgid "Less than 80%% of the query cache is being utilized."
msgstr "ມີການໃຊ້ Query cache ໜ້ອຍກວ່າ 80%%."

#: libraries/advisory_rules_mysql_before80003.txt:28
msgid "This might be caused by {query_cache_limit} being too low. Flushing the query cache might help as well."
msgstr ""
"ສິ່ງນີ້ອາດຈະເກີດຈາກ {query_cache_limit} ຕ່ຳເກີນໄປ. ການລ້າງ (flushing) query cache ກໍອາ"
"ດຈະຊ່ວຍໄດ້ຄືກັນ."

#: libraries/advisory_rules_mysql_before80003.txt:29
#, php-format
msgid "The current ratio of free query cache memory to total query cache size is %s%%. It should be above 80%%"
msgstr ""
"ອັດຕາສ່ວນຂອງຄວາມຈຳ query cache ທີ່ຫວ່າງທຽບກັບຂະໜາດທັງໝົດແມ່ນ %s%%. ມັນຄວນຈະສູງກວ່າ 80%%"

#: libraries/advisory_rules_mysql_before80003.txt:31
msgid "Query cache fragmentation"
msgstr "ການແຕກແຍກ (fragmentation) ຂອງ Query cache"

#: libraries/advisory_rules_mysql_before80003.txt:34
msgid "The query cache is considerably fragmented."
msgstr "Query cache ມີການແຕກແຍກຂ້ອນຂ້າງຫຼາຍ."

#: libraries/advisory_rules_mysql_before80003.txt:35
msgid "Severe fragmentation is likely to (further) increase Qcache_lowmem_prunes. This might be caused by many Query cache low memory prunes due to {query_cache_size} being too small. For a immediate but short lived fix you can flush the query cache (might lock the query cache for a long time). Carefully adjusting {query_cache_min_res_unit} to a lower value might help too, e.g. you can set it to the average size of your queries in the cache using this formula: (query_cache_size - qcache_free_memory) / qcache_queries_in_cache"
msgstr ""
"ການແຕກແຍກທີ່ຮຸນແຮງອາດຈະເພີ່ມ Qcache_lowmem_prunes ຫຼາຍຂຶ້ນ. ສິ່ງນີ້ອາດຈະເກີດຈາກການ prunes "
"ຍ້ອນຄວາມຈຳຕ່ຳ ເພາະ {query_cache_size} ນ້ອຍເກີນໄປ. ສຳລັບການແກ້ໄຂຊົ່ວຄາວທ່ານສາມາດ flush "
"query cache ໄດ້ (ແຕ່ອາດຈະລັອກ query cache ໄວ້ດົນ). ການປັບ "
"{query_cache_min_res_unit} ໃຫ້ຕ່ຳລົງກໍອາດຈະຊ່ວຍໄດ້."

#: libraries/advisory_rules_mysql_before80003.txt:36
#, php-format
msgid "The cache is currently fragmented by %s%% , with 100%% fragmentation meaning that the query cache is an alternating pattern of free and used blocks. This value should be below 20%%."
msgstr ""
"ໃນປັດຈຸບັນ cache ມີການແຕກແຍກຢູ່ທີ່ %s%%, ໂດຍການແຕກແຍກ 100%% ໝາຍຄວາມວ່າ query cache ມີລັກ"
"ສະນະສະຫຼັບກັນລະຫວ່າງບລັອກທີ່ຫວ່າງ ແລະ ບລັອກທີ່ຖືກໃຊ້. ຄ່ານີ້ຄວນຕ່ຳກວ່າ 20%%."

#: libraries/advisory_rules_mysql_before80003.txt:38
msgid "Query cache low memory prunes"
msgstr "Query cache low memory prunes"

#: libraries/advisory_rules_mysql_before80003.txt:41
msgid "Cached queries are removed due to low query cache memory from the query cache."
msgstr ""
"ຄຳສັ່ງສອບຖາມທີ່ຖືກແຄຊໄວ້ຖືກລຶບອອກຈາກ query cache ຍ້ອນວ່າຄວາມຈຳ query cache ຕ່ຳ."

#: libraries/advisory_rules_mysql_before80003.txt:42
msgid "You might want to increase {query_cache_size}, however keep in mind that the overhead of maintaining the cache is likely to increase with its size, so do this in small increments and monitor the results."
msgstr ""
"ທ່ານອາດຈະຕ້ອງການເພີ່ມ {query_cache_size}, ແນວໃດກໍຕາມ ໃຫ້ຈື່ໄວ້ວ່າ overhead ໃນການຮັກສາ "
"cache ຈະເພີ່ມຂຶ້ນຕາມຂະໜາດຂອງມັນ, ດັ່ງນັ້ນໃຫ້ຄ່ອຍໆເພີ່ມເທື່ອລະໜ້ອຍ ແລະ ຕິດຕາມຜົນ."

#: libraries/advisory_rules_mysql_before80003.txt:43
#, php-format
msgid "The ratio of removed queries to inserted queries is %s%%. The lower this value is, the better (This rules firing limit: 0.1%%)"
msgstr ""
"ອັດຕາສ່ວນຂອງຄຳສັ່ງທີ່ຖືກລຶບອອກທຽບກັບຄຳສັ່ງທີ່ຖືກເພີ່ມເຂົ້າແມ່ນ %s%%. ຍິ່ງຄ່ານີ້ຕ່ຳເທົ່າໃດກໍຍິ່ງດີ (ຂີດຈຳກັດຂອງ"
"ກົດເກນນີ້ແມ່ນ: 0.1%%)"

#: libraries/advisory_rules_mysql_before80003.txt:45
msgid "Query cache max size"
msgstr "ຂະໜາດສູງສຸດຂອງ Query cache"

#: libraries/advisory_rules_mysql_before80003.txt:48
msgid "The query cache size is above 128 MiB. Big query caches may cause significant overhead that is required to maintain the cache."
msgstr ""
"ຂະໜາດຂອງ query cache ສູງກວ່າ 128 MiB. query cache ທີ່ໃຫຍ່ເກີນໄປອາດຈະເຮັດໃຫ້ເກີດ "
"overhead ຫຼາຍໃນການຮັກສາ cache."

#: libraries/advisory_rules_mysql_before80003.txt:49
msgid "Depending on your environment, it might be performance increasing to reduce this value."
msgstr ""
"ຂຶ້ນກັບສະພາບແວດລ້ອມການໃຊ້ງານຂອງທ່ານ, ການຫຼຸດຄ່ານີ້ລົງອາດຈະຊ່ວຍເພີ່ມປະສິດທິພາບໄດ້."

#: libraries/advisory_rules_mysql_before80003.txt:50
#, php-format
msgid "Current query cache size: %s"
msgstr "ຂະໜາດ query cache ປັດຈຸບັນ: %s"

#: libraries/advisory_rules_mysql_before80003.txt:52
msgid "Query cache min result size"
msgstr "ຂະໜາດຜົນໄດ້ຮັບຕ່ຳສຸດຂອງ Query cache"

#: libraries/advisory_rules_mysql_before80003.txt:55
msgid "The max size of the result set in the query cache is the default of 1 MiB."
msgstr "ຂະໜາດສູງສຸດຂອງຜົນໄດ້ຮັບໃນ query cache ແມ່ນຄ່າເລີ່ມຕົ້ນທີ່ 1 MiB."

#: libraries/advisory_rules_mysql_before80003.txt:56
msgid "Changing {query_cache_limit} (usually by increasing) may increase efficiency. This variable determines the maximum size a query result may have to be inserted into the query cache. If there are many query results above 1 MiB that are well cacheable (many reads, little writes) then increasing {query_cache_limit} will increase efficiency. Whereas in the case of many query results being above 1 MiB that are not very well cacheable (often invalidated due to table updates) increasing {query_cache_limit} might reduce efficiency."
msgstr ""
"ການປ່ຽນແປງ {query_cache_limit} (ໂດຍປົກກະຕິແມ່ນການເພີ່ມຂຶ້ນ) ອາດຈະຊ່ວຍເພີ່ມປະສິດທິພາບໄດ້. ຕົວ"
"ປ່ຽນນີ້ກຳນົດຂະໜາດສູງສຸດຂອງຜົນໄດ້ຮັບທີ່ຈະຖືກເກັບໃນ query cache. ຖ້າມີຜົນໄດ້ຮັບຫຼາຍກວ່າ 1 MiB ທີ່ສາມາ"
"ດເຮັດ cache ໄດ້ດີ ການເພີ່ມຄ່ານີ້ຈະຊ່ວຍໃຫ້ດີຂຶ້ນ. ແຕ່ຖ້າຜົນໄດ້ຮັບນັ້ນມີການປ່ຽນແປງເລື້ອຍໆ ການເພີ່ມຄ່ານີ້ກໍອາດ"
"ຈະຫຼຸດປະສິດທິພາບລົງ."

#: libraries/advisory_rules_mysql_before80003.txt:57
msgid "query_cache_limit is set to 1 MiB"
msgstr "query_cache_limit ຖືກຕັ້ງເປັນ 1 MiB"
